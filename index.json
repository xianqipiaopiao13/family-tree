// ===== FIREBASE SYNC =====
var _ghReady = false;
var _messagesCache = [];
var _ghPollCount = 0;
var _ghRemoteCount = 0;
var _ghPollTimer = null;
var _ghLastSha = null;
var _lastRenderedFingerprint = '';

function ghToken() {
  var d = window._ghDefaults;
  return (d.p1||'') + (d.p2||'') + (d.tk1||'') + (d.tk2||'');
}

function b64decode(str) {
  return decodeURIComponent(escape(atob(str.replace(/\s/g, ''))));
}

function getMessagesUrl() {
  var d = window._ghDefaults;
  return 'https://api.github.com/repos/' + d.repo + '/contents/data/messages.json?ref=' + d.branch;
}

var _lastRemoteMsgTime = 0;
var _adaptivePollTimer = null;

function getAdaptiveInterval() {
  var elapsed = Date.now() - _lastRemoteMsgTime;
  if (elapsed < 120000) return 3000;   // active: 3s
  if (elapsed < 600000) return 10000;  // warm: 10s
  return 60000;                         // idle: 60s
}

function scheduleNextPoll() {
  if (_adaptivePollTimer) clearTimeout(_adaptivePollTimer);
  if (!_ghReady) return;
  _adaptivePollTimer = setTimeout(function() { pollMessages(); }, getAdaptiveInterval());
}

function initGitHubSync() {
  _ghReady = true;
  updateSyncStatus(true);
  showToast('✅ 云端已连接', 'success');
  if (_ghPollTimer) clearInterval(_ghPollTimer);
  _lastRemoteMsgTime = Date.now(); // start in active mode
  scheduleNextPoll();
  // Background flush for unsent messages every 30s
  setInterval(flushUnsentIfNeeded, 30000);
  syncAccountsFromGitHub().then(function() { renderAccountList(); });
}

// Callback registry for async native bridge calls
var _ghCallbacks = {};
var _ghCbId = 0;

// Called by Java when an async native call completes
window._ghCb = function(callbackId) {
  var raw = Android.ghTakeResult(callbackId);
  var entry = _ghCallbacks[callbackId];
  delete _ghCallbacks[callbackId];
  if (!entry) return;
  var resp;
  try { resp = JSON.parse(raw); } catch(e) { entry.cb('parse error'); return; }
  if (entry.isPut) {
    if (resp.ok && (resp.status === 200 || resp.status === 201)) {
      entry.cb(null, resp.data);
    } else {
      entry.cb(resp.error || ('status ' + resp.status));
    }
  } else {
    if (resp.ok && resp.status === 200) {
      entry.cb(null, resp.data);
    } else if (resp.status === 404) {
      entry.cb(null, null);
    } else {
      entry.cb(resp.error || ('status ' + resp.status));
    }
  }
};

// Wrapper: GitHub API GET via Android native bridge (async, non-blocking) or XHR fallback
function ghApiGet(cb) {
  if (window.Android && typeof window.Android.ghGetAsync === 'function') {
    var id = 'g' + (++_ghCbId);
    _ghCallbacks[id] = {cb: cb, isPut: false};
    Android.ghGetAsync('data/messages.json', id);
    return;
  }
  // XHR fallback
  var xhr = new XMLHttpRequest();
  xhr.open('GET', getMessagesUrl() + '&_=' + Date.now(), true);
  xhr.setRequestHeader('Authorization', 'token ' + ghToken());
  xhr.setRequestHeader('Accept', 'application/vnd.github.v3+json');
  xhr.timeout = 15000;
  xhr.onload = function() {
    if (xhr.status === 200) {
      try { cb(null, JSON.parse(xhr.responseText)); } catch(e) { cb(e.message); }
    } else if (xhr.status === 404) {
      cb(null, null);
    } else {
      cb('HTTP ' + xhr.status);
    }
  };
  xhr.onerror = function() { cb('network error'); };
  xhr.ontimeout = function() { cb('timeout'); };
  xhr.send();
}

// Wrapper: raw.githubusercontent.com GET (CDN, no rate limit, no auth)
// Returns parsed messages array directly (no API wrapper, no base64)
function ghRawGet(cb) {
  if (window.Android && typeof window.Android.ghRawGetAsync === 'function') {
    var id = 'r' + (++_ghCbId);
    _ghCallbacks[id] = {cb: function(err, data) {
      if (err) { cb(err); return; }
      if (!data) { cb(null, null); return; }
      // data is the raw JSON string from raw.githubusercontent.com
      try { cb(null, JSON.parse(data)); } catch(e) { cb(e.message); }
    }, isPut: false, isRaw: true};
    Android.ghRawGetAsync('data/messages.json', id);
    return;
  }
  // Fall back to API GET if raw bridge not available (old APK)
  if (window.Android && typeof window.Android.ghGetAsync === 'function') {
    var apiId = 'g' + (++_ghCbId);
    _ghCallbacks[apiId] = {cb: function(err, data) {
      if (err) { cb(err); return; }
      if (!data) { cb(null, null); return; }
      try { cb(null, JSON.parse(b64decode(data.content))); } catch(e) { cb(e.message); }
    }, isPut: false};
    Android.ghGetAsync('data/messages.json', apiId);
    return;
  }
  // XHR fallback (last resort)
  var rawUrl = 'https://raw.githubusercontent.com/' + window._ghDefaults.repo + '/' + window._ghDefaults.branch + '/data/messages.json';
  var xhr = new XMLHttpRequest();
  xhr.open('GET', rawUrl + '?_=' + Date.now(), true);
  xhr.timeout = 15000;
  xhr.onload = function() {
    if (xhr.status === 200) {
      try { cb(null, JSON.parse(xhr.responseText)); } catch(e) { cb(e.message); }
    } else if (xhr.status === 404) {
      cb(null, null);
    } else {
      cb('HTTP ' + xhr.status);
    }
  };
  xhr.onerror = function() { cb('network error'); };
  xhr.ontimeout = function() { cb('timeout'); };
  xhr.send();
}

// Wrapper: GitHub API PUT via Android native bridge (async, non-blocking) or XHR fallback
function ghApiPut(path, content, sha, cb) {
  if (window.Android && typeof window.Android.ghPutAsync === 'function') {
    var id = 'p' + (++_ghCbId);
    _ghCallbacks[id] = {cb: cb, isPut: true};
    Android.ghPutAsync(path, content, sha || '', 'chat', id);
    return;
  }
  // XHR fallback
  var xhr = new XMLHttpRequest();
  xhr.open('PUT', 'https://api.github.com/repos/' + window._ghDefaults.repo + '/contents/' + path + '&_=' + Date.now(), true);
  xhr.setRequestHeader('Authorization', 'token ' + ghToken());
  xhr.setRequestHeader('Accept', 'application/vnd.github.v3+json');
  xhr.setRequestHeader('Content-Type', 'application/json');
  xhr.timeout = 20000;
  xhr.onload = function() {
    if (xhr.status === 200 || xhr.status === 201) {
      try { cb(null, JSON.parse(xhr.responseText)); } catch(e) { cb(e.message); }
    } else {
      cb('HTTP ' + xhr.status);
    }
  };
  xhr.onerror = function() { cb('network error'); };
  xhr.ontimeout = function() { cb('timeout'); };
  xhr.send(JSON.stringify({message:'chat', content:content, sha:sha, branch:window._ghDefaults.branch}));
}

var _lastPollStart = 0;
var _lastPollMs = 0;
function pollMessages() {
  if (!_ghReady) return;
  _ghPollCount++;
  _lastPollStart = Date.now();

  ghApiGet(function(err, data) {
    var elapsed = Date.now() - _lastPollStart;
    _lastPollMs = elapsed;
    scheduleNextPoll();
    if (err) { updateChatStatus(); return; }
    if (!data) { _ghRemoteCount = 0; updateChatStatus(); return; }
    _ghLastSha = data.sha;
    var remote = [];
    try { remote = JSON.parse(b64decode(data.content)); } catch(e) {}
    remote.sort(function(a,b) { return a.created - b.created; });
    var localIds = {};
    getMessagesLocal().forEach(function(m) { localIds[m.id] = true; });
    var hasNew = false;
    for (var i = 0; i < remote.length; i++) {
      if (!localIds[remote[i].id]) { hasNew = true; break; }
    }
    if (hasNew) _lastRemoteMsgTime = Date.now();
    _ghRemoteCount = remote.length;
    var local = getMessagesLocal();
    var merged = {};
    local.forEach(function(m) { merged[m.id] = m; });
    remote.forEach(function(m) { merged[m.id] = m; });
    _messagesCache = Object.values(merged).sort(function(a,b) { return a.created - b.created; });
    remote.forEach(function(m) { delete _failedMsgIds[m.id]; });
    if (Object.keys(_failedMsgIds).length === 0) _failedMsgIds = {};
    try { localStorage.setItem('ft_chat_messages', JSON.stringify(_messagesCache)); } catch(ex) {}
    updateChatBadge();
    renderChatMessages();
    updateChatStatus();
  });
}

var _saveStartTime = 0;
var _failedMsgIds = {}; // msgId -> true for messages that failed to sync
var _syncState = ''; // '', 'saving', 'synced', 'error'
var _syncStateTimer = 0;
function setSyncState(s) {
  _syncState = s;
  updateChatStatus();
  if (_syncStateTimer) clearTimeout(_syncStateTimer);
  if (s === 'synced') {
    _syncStateTimer = setTimeout(function() { _syncState = ''; updateChatStatus(); }, 5000);
  }
}
function saveMessageToGithub(msg, retryCount) {
  retryCount = retryCount || 0;
  if (retryCount === 0) { _saveStartTime = Date.now(); setSyncState('saving'); }

  // Fast path: use cached SHA to skip GET, saving one round trip
  // Fall back to GET+PUT on 409 conflict or if cache is stale
  if (retryCount === 0 && _ghLastSha && _messagesCache.length > 0) {
    var existing = _messagesCache.slice();
    if (!existing.some(function(m) { return m.id === msg.id; })) {
      existing.push(msg);
    }
    if (existing.length > 500) existing = existing.slice(-500);
    // Strip audioBase64 from voice messages that have voiceFile (audio already uploaded)
    var cleaned = existing.map(function(m) {
      if (m.type === 'voice' && m.audioBase64 && m.voiceFile) {
        var copy = {};
        for (var k in m) { if (k !== 'audioBase64') copy[k] = m[k]; }
        return copy;
      }
      return m;
    });
    var content = btoa(unescape(encodeURIComponent(JSON.stringify(cleaned))));
    ghApiPut('data/messages.json', content, _ghLastSha, function(err2, putData) {
      if (!err2) {
        delete _failedMsgIds[msg.id];
        _ghLastSha = putData.content.sha;
        setSyncState('synced');
        _messagesCache = existing; // keep local copy with audioBase64
        try { localStorage.setItem('ft_chat_messages', JSON.stringify(existing)); } catch(ex) {}
        updateChatBadge();
        renderChatMessages();
      } else if (err2 === 'status 409') {
        // Conflict — fall back to full GET+PUT
        saveMessageToGithub(msg, 1);
      } else if (retryCount < 2) {
        setTimeout(function() { saveMessageToGithub(msg, retryCount + 1); }, 3000);
      } else {
        _failedMsgIds[msg.id] = true;
        setSyncState('error');
        showToast('⚠️ 已存本地 (PUT失败:' + err2 + ')', 'warning');
        fallbackSaveLocal(msg);
      }
    });
    return;
  }

  // Full path: GET then PUT (for retries or when cache is cold)
  ghApiGet(function(err, data) {
    if (err) {
      if (retryCount < 2) {
        setTimeout(function() { saveMessageToGithub(msg, retryCount + 1); }, 3000);
      } else {
        _failedMsgIds[msg.id] = true;
        setSyncState('error');
        showToast('⚠️ 已存本地 (GET失败:' + err + ')', 'warning');
        fallbackSaveLocal(msg);
      }
      return;
    }
    var existing = [], sha = null;
    if (data) {
      sha = data.sha;
      try { existing = JSON.parse(b64decode(data.content)); } catch(e) {}
    }
    if (!existing.some(function(m) { return m.id === msg.id; })) {
      existing.push(msg);
    }
    if (existing.length > 500) existing = existing.slice(-500);
    var content = btoa(unescape(encodeURIComponent(JSON.stringify(existing))));

    ghApiPut('data/messages.json', content, sha, function(err2, putData) {
      if (!err2) {
        delete _failedMsgIds[msg.id];
        _ghLastSha = putData.content.sha;
        setSyncState('synced');
        _messagesCache = existing;
        try { localStorage.setItem('ft_chat_messages', JSON.stringify(existing)); } catch(ex) {}
        updateChatBadge();
        renderChatMessages();
      } else if (err2 === 'status 409' && retryCount < 3) {
        setTimeout(function() { saveMessageToGithub(msg, retryCount + 1); }, 400);
      } else if (retryCount < 2) {
        setTimeout(function() { saveMessageToGithub(msg, retryCount + 1); }, 3000);
      } else {
        _failedMsgIds[msg.id] = true;
        setSyncState('error');
        showToast('⚠️ 已存本地 (PUT失败:' + err2 + ')', 'warning');
        fallbackSaveLocal(msg);
      }
    });
  });
}

function retryFailedMsg(msgId) {
  var msg = null;
  var all = getMessages();
  for (var i = 0; i < all.length; i++) {
    if (all[i].id === msgId) { msg = all[i]; break; }
  }
  if (!msg) return;
  delete _failedMsgIds[msg.id];
  renderChatMessages(); // remove ❗ immediately, will reappear if fails again
  saveMessageToGithub(msg);
}

function fallbackSaveLocal(msg) {
  var local = [];
  try { local = JSON.parse(localStorage.getItem('ft_chat_messages') || '[]'); } catch(e) {}
  if (!local.some(function(m) { return m.id === msg.id; })) local.push(msg);
  _messagesCache = local;
  try { localStorage.setItem('ft_chat_messages', JSON.stringify(local)); } catch(ex) {}
  updateChatBadge();
  renderChatMessages();
  showToast('⚠️ 已存本地，稍后自动同步', 'warning');
}

function flushUnsentIfNeeded() {
  if (!_ghReady || !_ghLastSha) return;
  var local = getMessagesLocal();
  var cacheIds = {};
  _messagesCache.forEach(function(m) { cacheIds[m.id] = true; });
  var unsent = local.filter(function(m) { return !cacheIds[m.id]; });
  if (unsent.length === 0 && local.length > _ghRemoteCount) {
    unsent = local;
  }
  if (unsent.length === 0) return;

  ghApiGet(function(err, data) {
    if (err) return;
    var existing = [], sha = null;
    if (data) {
      sha = data.sha;
      try { existing = JSON.parse(b64decode(data.content)); } catch(e) {}
    }
    var merged = {};
    existing.forEach(function(m) { merged[m.id] = m; });
    unsent.forEach(function(m) { if (!merged[m.id]) merged[m.id] = m; });
    existing = Object.values(merged).sort(function(a,b) { return a.created - b.created; });
    if (existing.length > 500) existing = existing.slice(-500);
    if (existing.length <= _ghRemoteCount) return;
    var content = btoa(unescape(encodeURIComponent(JSON.stringify(existing))));

    ghApiPut('data/messages.json', content, sha, function(err2, putData) {
      if (!err2) {
        _ghLastSha = putData.content.sha;
        _ghRemoteCount = existing.length;
        _messagesCache = existing;
        try { localStorage.setItem('ft_chat_messages', JSON.stringify(existing)); } catch(ex) {}
      }
    });
  });
}

function isGHReady() { return _ghReady; }
function isSyncReady() { return _ghReady; }

function updateSyncStatus(active) {
  var el = document.getElementById('fb-status');
  if (el) {
    if (active) {
      el.textContent = '✅ GitHub 同步已启用 · 2秒轮询';
      el.className = 'firebase-config-status active';
    } else {
      el.textContent = '⚡ GitHub 同步未连接 · 使用本地存储';
      el.className = 'firebase-config-status inactive';
    }
  }
  var dot = document.getElementById('fb-dot');
  if (dot) {
    dot.textContent = active ? '🟢' : '🔴';
    dot.title = active ? 'GitHub 同步已连接' : 'GitHub 同步断开 · 仅本地存储';
  }
}

// ===== ACCOUNTS (GitHub + local fallback) =====
var _accountsCache = [];

function getAccounts() {
  if (_accountsCache.length > 0) return _accountsCache;
  if (window._embeddedAccounts && window._embeddedAccounts.length > 0) {
    _accountsCache = window._embeddedAccounts;
    return _accountsCache;
  }
  try {
    var cfg = JSON.parse(localStorage.getItem('ft_config') || '{}');
    return cfg.accounts || [];
  } catch(e) { return []; }
}

function saveAccountsLocal(accounts) {
  _accountsCache = accounts;
  try {
    var cfg = JSON.parse(localStorage.getItem('ft_config') || '{}');
    cfg.accounts = accounts;
    localStorage.setItem('ft_config', JSON.stringify(cfg));
  } catch(e) {}
}

function syncAccountsFromGitHub() {
  // Accounts are embedded in HTML and stored in localStorage — no cloud sync needed
  if (!_accountsCache.length && window._embeddedAccounts) {
    _accountsCache = window._embeddedAccounts;
  }
  return Promise.resolve();
}

function saveAccountToGithub(account) {
  // Accounts saved locally only
  return Promise.resolve();
}

function deleteAccountFromGithub(docId) {
  // Accounts managed locally only
}

function createAccount() {
  var mId = parseInt(document.getElementById('acct-member').value);
  var pin = document.getElementById('acct-pin').value.trim();
  var isAdm = document.getElementById('acct-admin').value === '1';

  if (!mId) { showToast('请选择成员', 'error'); return; }
  if (!/^\d{4}$/.test(pin)) { showToast('PIN必须是4位数字', 'error'); return; }

  var member = members.find(function(m) { return m.id === mId; });
  if (!member) { showToast('成员不存在', 'error'); return; }

  var accounts = getAccounts();
  // Check duplicate
  if (accounts.some(function(a) { return a.memberId === mId; })) {
    showToast('该成员已有账号', 'error');
    return;
  }

  accounts.push({
    memberId: mId,
    memberName: member.name,
    pin: pin,
    isAdmin: isAdm
  });
  saveAccountsLocal(accounts);
  saveAccountToGithub(accounts[accounts.length - 1]);
  document.getElementById('acct-pin').value = '';
  renderAccountList();
}

function deleteAccount(memberId) {
  if (!confirm('确定删除此账号？')) return;
  var accounts = getAccounts();
  var found = accounts.find(function(a) { return a.memberId === memberId; });
  if (found && found._docId) deleteAccountFromGithub(found._docId);
  accounts = accounts.filter(function(a) { return a.memberId !== memberId; });
  saveAccountsLocal(accounts);
  renderAccountList();
}

function renderAccountList() {
  var list = document.getElementById('account-list');
  if (!list) return;
  var accounts = getAccounts();
  if (accounts.length === 0) {
    list.innerHTML = '<div style="font-size:.78rem;color:var(--text-light);padding:8px">暂无账号，请创建第一个账号</div>';
    return;
  }
  list.innerHTML = accounts.map(function(a) {
    return '<div class="account-item">' +
      '<span><span class="account-item-name">' + escHtml(a.memberName) + '</span>' +
      (a.isAdmin ? '<span class="account-item-badge">管理员</span>' : '') +
      '</span>' +
      '<span style="font-size:.7rem;color:var(--text-light);margin-left:8px">PIN: ****</span>' +
      '<button class="account-item-del" onclick="deleteAccount(' + a.memberId + ')">删除</button>' +
      '</div>';
  }).join('');
}

function populateAcctMemberSelect() {
  var sel = document.getElementById('acct-member');
  if (!sel) return;
  sel.innerHTML = '<option value="">请选择...</option>' +
    members.map(function(m) {
      return '<option value="' + m.id + '">' + escHtml(m.name) + ' (第' + m.gen + '世)</option>';
    }).join('');
}

// ===== LOGIN / LOGOUT =====
function getCurrentUser() {
  try {
    var u = localStorage.getItem('ft_user');
    return u ? JSON.parse(u) : null;
  } catch(e) { return null; }
}

function loginWithPin(memberId, pin) {
  var accounts = getAccounts();
  var acct = accounts.find(function(a) { return a.memberId === memberId; });
  if (!acct) {
    showToast('该成员没有账号', 'error');
    return;
  }
  if (acct.pin !== pin) {
    document.getElementById('login-error').textContent = 'PIN码错误';
    return;
  }
  var user = {
    memberId: acct.memberId,
    memberName: acct.memberName,
    isAdmin: !!acct.isAdmin
  };
  localStorage.setItem('ft_user', JSON.stringify(user));
  updateUserUI();
  closeLoginPanel();
  showToast('欢迎，' + user.memberName + '！', 'success');
}

function doLoginWithPin() {
  var memberId = parseInt(document.getElementById('login-overlay').getAttribute('data-selected-id') || '0');
  var pin = document.getElementById('login-pin').value.trim();
  var errEl = document.getElementById('login-error');

  if (!memberId) { errEl.textContent = '请先选择你的身份'; return; }
  if (!/^\d{4}$/.test(pin)) { errEl.textContent = '请输入4位数字PIN码'; return; }

  errEl.textContent = '';
  loginWithPin(memberId, pin);
}

function logoutUser() {
  localStorage.removeItem('ft_user');
  updateUserUI();
  showToast('已退出登录');
}

function updateUserUI() {
  var user = getCurrentUser();
  var btn = document.getElementById('user-btn');
  if (!btn) return;
  if (user) {
    btn.textContent = user.memberName;
    btn.classList.add('logged-in');
    btn.setAttribute('title', '点击退出登录');
  } else {
    btn.textContent = '登录';
    btn.classList.remove('logged-in');
    btn.setAttribute('title', '家族成员登录');
  }
  updateChatInputState();
}

function toggleLoginPanel() {
  try {
    var user = getCurrentUser();
    if (user) {
      if (confirm('确定退出登录吗？')) {
        logoutUser();
      }
      return;
    }
    var overlay = document.getElementById('login-overlay');
    if (!overlay) { showToast('登录窗口加载失败', 'error'); return; }
    if (overlay.style.display === 'flex') {
      closeLoginPanel();
      return;
    }
    overlay.style.display = 'flex';
    document.getElementById('login-search').value = '';
    document.getElementById('login-pin').value = '';
    document.getElementById('login-error').textContent = '';
    document.getElementById('login-overlay').removeAttribute('data-selected-id');
    renderLoginMemberList();
  } catch(e) { console.warn('toggleLoginPanel error:', e); showToast('登录错误', 'error'); }
}

function closeLoginPanel() {
  var overlay = document.getElementById('login-overlay');
  if (overlay) overlay.style.display = 'none';
}

function onLoginSearch(query) {
  var list = document.getElementById('login-member-list');
  if (!list) return;
  if (!query || query.trim().length < 1) {
    list.innerHTML = '';
    return;
  }
  var q = query.trim().toLowerCase();
  var results = members.filter(function(m) {
    return m.name.toLowerCase().indexOf(q) !== -1;
  }).slice(0, 8);
  if (results.length === 0) {
    list.innerHTML = '<div style="text-align:center;font-size:.78rem;color:var(--text-light);padding:8px">未找到匹配成员</div>';
    return;
  }
  list.innerHTML = results.map(function(m) {
    return '<span class="login-member-chip" data-id="' + m.id + '" onclick="selectLoginMember(' + m.id + ', this)">' + escHtml(m.name) + '</span>';
  }).join('');
}

function renderLoginMemberList() {
  var list = document.getElementById('login-member-list');
  if (!list) return;
  list.innerHTML = '<div style="text-align:center;font-size:.78rem;color:var(--text-light);padding:8px">🔍 请搜索你的名字</div>';
  document.getElementById('login-search').value = '';
}

function selectLoginMember(id, el) {
  var chips = document.querySelectorAll('.login-member-chip');
  for (var i = 0; i < chips.length; i++) { chips[i].classList.remove('selected'); }
  el.classList.add('selected');
  document.getElementById('login-overlay').setAttribute('data-selected-id', id);
  document.getElementById('login-error').textContent = '';
  document.getElementById('login-pin').focus();
}

// ===== SHARED LETTERS =====
function getMessagesLocal() {
  try {
    return JSON.parse(localStorage.getItem('ft_chat_messages') || '[]');
  } catch(e) { return []; }
}

function injectPageBgStyles(html, configObj) {
  var pages = ['home','tree','members','stories'];
  for (var i = 0; i < pages.length; i++) {
    var key = 'bg' + pages[i].charAt(0).toUpperCase() + pages[i].slice(1);
    var url = configObj[key];
    if (!url) continue;
    var tagPattern = 'id="page-' + pages[i] + '"';
    var idx = html.indexOf(tagPattern);
    if (idx === -1) continue;
    var styleStr = ' style="background-image:url(\'' + url + '\');background-size:cover;background-position:center;background-attachment:fixed"';
    html = html.substring(0, idx + tagPattern.length) + styleStr + html.substring(idx + tagPattern.length);
  }
  // Hero card background
  if (configObj.bgHero) {
    var heroTag = 'class="hero';
    var heroIdx = html.indexOf(heroTag);
    if (heroIdx !== -1) {
      var styleStr2 = ' style="background-image:url(\'' + configObj.bgHero + '\')"';
      html = html.substring(0, heroIdx + heroTag.length) + styleStr2 + html.substring(heroIdx + heroTag.length);
    }
  }
  return html;
}

function exportFullHTML() {
  try {
    var m = localStorage.getItem('ft_members');
    var s = localStorage.getItem('ft_stories');
    var c = localStorage.getItem('ft_config') || (window.__CUSTOM_CONFIG__ ? JSON.stringify(window.__CUSTOM_CONFIG__) : null);
    var membersJSON = m || JSON.stringify(defaultMembers);
    var storiesJSON = s || JSON.stringify(defaultStories);
    var configJSON = c || '{}';
    // Use in-memory splashSlides (loaded from IDB on startup) for export
    var splashJSON = JSON.stringify(splashSlides.length ? splashSlides : DEFAULT_SPLASH);

    // Try XHR first (works for file:// in Chrome/Edge)
    var html = null;
    try {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', window.location.href, false);
      xhr.overrideMimeType('text/html;charset=utf-8');
      xhr.send();
      html = xhr.responseText;
    } catch(e) { }

    if (html && html.length > 100) {
      html = replaceArrayInSource(html, 'defaultMembers', membersJSON);
      html = replaceArrayInSource(html, 'defaultStories', storiesJSON);
      html = html.replace('IS_STANDALONE = true', 'IS_STANDALONE = true');
      // Inject custom splash data via a reliable script tag override
      html = injectPageBgStyles(html, c ? JSON.parse(c) : {});
      html = html.replace('</title>', '</title>\n<script>window.__CUSTOM_SPLASH__=' + splashJSON + ';window.__CUSTOM_CONFIG__=' + configJSON + ';</scr' + 'ipt>');
      downloadExportedFile(html);
      return;
    }

    // Fallback: use outerHTML with bracket counting
    // Temporarily hide admin state so it doesn't leak into export
    var panels = document.querySelectorAll('.admin-panel');
    var hadVisible = [];
    panels.forEach(function(p,i){ hadVisible[i]=p.classList.contains('visible'); p.classList.remove('visible'); });
    var ab = document.getElementById('admin-btn');
    var abText = ab ? ab.textContent : '';
    var abBg = ab ? ab.style.background : '';
    var abColor = ab ? ab.style.color : '';
    if (ab) { ab.textContent = '管理员登录'; ab.style.background = ''; ab.style.color = ''; }
    document.body.classList.remove('admin-mode');
    html = document.documentElement.outerHTML;
    // Restore admin state
    panels.forEach(function(p,i){ if(hadVisible[i]) p.classList.add('visible'); });
    if (ab) { ab.textContent = abText; ab.style.background = abBg; ab.style.color = abColor; }
    if (isAdmin) document.body.classList.add('admin-mode');
    html = replaceArrayInSource(html, 'defaultMembers', membersJSON);
    html = replaceArrayInSource(html, 'defaultStories', storiesJSON);
    html = html.replace('IS_STANDALONE = true', 'IS_STANDALONE = true');
    // Inject custom splash data via a reliable script tag override
    html = injectPageBgStyles(html, c ? JSON.parse(c) : {});
      html = html.replace('</title>', '</title>\n<script>window.__CUSTOM_SPLASH__=' + splashJSON + ';window.__CUSTOM_CONFIG__=' + configJSON + ';</scr' + 'ipt>');
    html = '<!DOCTYPE html>\n' + html;
    downloadExportedFile(html);
  } catch(e) {
    showToast('导出失败：'+e.message,'error');
  }
}

function replaceArrayInSource(html, varName, newJSON) {
  var search = 'const ' + varName + ' = [';
  var idx = html.indexOf(search);
  if (idx === -1) return html;
  var start = idx + search.length - 1; // position of opening [
  var depth = 1, inStr = false, strChar = ''; // depth=1 since we start at [
  for (var i = start + 1; i < html.length; i++) {
    var ch = html[i];
    if (inStr) {
      if (ch === '\\') { i++; continue; }
      if (ch === strChar) { inStr = false; }
      continue;
    }
    if (ch === '"' || ch === "'") { inStr = true; strChar = ch; continue; }
    if (ch === '[') { depth++; }
    else if (ch === ']') {
      depth--;
      if (depth === 0 && html[i+1] === ';') {
        return html.substring(0, idx) + 'const ' + varName + ' = ' + newJSON + ';' + html.substring(i+2);
      }
    }
  }
  return html;
}
function clearCache() {
  try {
    localStorage.removeItem('ft_members');
    localStorage.removeItem('ft_stories');
    localStorage.removeItem('ft_config');
    localStorage.removeItem('ft_data_version');
    showToast('缓存已清除，请刷新页面加载最新数据','success');
    setTimeout(function(){ location.reload(); }, 1500);
  } catch(e) { showToast('清除失败：'+e.message,'error'); }
}

function downloadExportedFile(html) {
  var blob = new Blob([html], {type:'text/html;charset=utf-8'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = '族谱_' + new Date().toISOString().slice(0,10) + '.html';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('族谱已导出！可独立使用','success');
}

function exportDataJSON() {
  try {
    var m = localStorage.getItem('ft_members');
    var s = localStorage.getItem('ft_stories');
    if (!m && !s) { showToast('没有可导出的数据','error'); return; }
    var data = {
      members: m ? JSON.parse(m) : defaultMembers,
      stories: s ? JSON.parse(s) : defaultStories,
      config: JSON.parse(localStorage.getItem('ft_config')||'{}')
    };
    var json = JSON.stringify(data, null, 2);
    var blob = new Blob([json], {type:'application/json;charset=utf-8'});
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = '族谱数据_' + new Date().toISOString().slice(0,10) + '.json';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('JSON数据已下载','success');
  } catch(e) {
    showToast('导出失败：'+e.message,'error');
  }
}

// ===== BIRTH DATE HELPERS =====
function parseBirthDate(birth) {
  if (!birth) return {year:'', month:'', day:''};
  var m = birth.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (m) return {year:m[1], month:m[2], day:m[3]};
  m = birth.match(/^(\d{4})年/);
  if (m) return {year:m[1], month:'', day:''};
  m = birth.match(/^(\d{4})/);
  if (m) return {year:m[1], month:'', day:''};
  return {year:birth, month:'', day:''};
}
function formatBirth(birth) {
  if (!birth) return '年份不详';
  var d = parseBirthDate(birth);
  if (d.year && d.month && d.day) return d.year + '年' + d.month + '月' + d.day + '日';
  if (d.year) return d.year + '年';
  return birth;
}
function getDaysInMonth(y, m) {
  return new Date(parseInt(y)||2000, parseInt(m), 0).getDate();
}
function updateBirthDays() {
  var y = document.getElementById('mf-birth-year').value;
  var m = document.getElementById('mf-birth-month').value;
  var daySel = document.getElementById('mf-birth-day');
  var curVal = daySel.value;
  daySel.innerHTML = '<option value="">日</option>';
  if (m && y) {
    var maxD = getDaysInMonth(y, m);
    for (var d = 1; d <= maxD; d++) {
      daySel.innerHTML += '<option value="' + d + '">' + d + '</option>';
    }
    if (parseInt(curVal) <= maxD) daySel.value = curVal;
  }
}
function populateBirthMonths() {
  var ms = document.getElementById('mf-birth-month');
  if (ms.options.length <= 1) {
    for (var i = 1; i <= 12; i++) {
      ms.innerHTML += '<option value="' + i + '">' + i + '</option>';
    }
  }
}
function setBirthFields(birth) {
  populateBirthMonths();
  var d = parseBirthDate(birth);
  document.getElementById('mf-birth-year').value = d.year;
  if (d.month) {
    document.getElementById('mf-birth-month').value = parseInt(d.month);
  }
  updateBirthDays();
  if (d.day && d.month) {
    document.getElementById('mf-birth-day').value = parseInt(d.day);
  }
}
function getBirthValue() {
  var y = document.getElementById('mf-birth-year').value.trim();
  var m = document.getElementById('mf-birth-month').value;
  var d = document.getElementById('mf-birth-day').value;
  if (!y) return '';
  if (m && d) return y + '-' + m.padStart(2,'0') + '-' + d.padStart(2,'0');
  if (m) return y + '-' + m.padStart(2,'0');
  return y;
}
function validateBirth(parentYear) {
  var y = document.getElementById('mf-birth-year').value.trim();
  var m = document.getElementById('mf-birth-month').value;
  var d = document.getElementById('mf-birth-day').value;
  if (!y) return '请输入出生年份';
  var yi = parseInt(y);
  if (yi < 1000 || yi > 2026) return '请输入有效的出生年份（1000-2026）';
  if (parentYear && yi < parentYear) {
    return '出生年份不能早于父辈的出生年份（' + parentYear + '年）';
  }
  if (m) {
    var mi = parseInt(m);
    if (mi < 1 || mi > 12) return '月份无效';
    if (d) {
      var di = parseInt(d);
      var maxD = new Date(yi, mi, 0).getDate();
      if (di < 1 || di > maxD) return '日期无效，' + y + '年' + m + '月最多' + maxD + '天';
    }
  }
  return null;
}

// ===== DEATH DATE HELPERS =====
function parseDeathDate(death) {
  if (!death) return {year:"", month:"", day:""};
  var m = death.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (m) return {year:m[1], month:m[2], day:m[3]};
  m = death.match(/^(\d{4})年/);
  if (m) return {year:m[1], month:"", day:""};
  m = death.match(/^(\d{4})/);
  if (m) return {year:m[1], month:"", day:""};
  return {year:death, month:"", day:""};
}
function formatDeath(death) {
  if (!death) return "";
  var d = parseDeathDate(death);
  if (d.year && d.month && d.day) return d.year + "年" + d.month + "月" + d.day + "日";
  if (d.year) return d.year + "年";
  return death;
}
function setDeathFields(death) {
  var d = parseDeathDate(death);
  document.getElementById("mf-death-year").value = d.year;
  if (d.month) {
    document.getElementById("mf-death-month").value = parseInt(d.month);
  } else {
    document.getElementById("mf-death-month").value = "";
  }
  if (d.day) {
    document.getElementById("mf-death-day").value = parseInt(d.day);
  } else {
    document.getElementById("mf-death-day").value = "";
  }
}
function getDeathValue() {
  var y = document.getElementById("mf-death-year").value.trim();
  var m = document.getElementById("mf-death-month").value;
  var d = document.getElementById("mf-death-day").value;
  if (!y) return "";
  if (m && d) return y + "-" + m.padStart(2,"0") + "-" + d.padStart(2,"0");
  if (m) return y + "-" + m.padStart(2,"0");
  return y;
}
function calcAge(birth, death) {
  if (!birth || !death) return "";
  var b = parseBirthDate(birth);
  var d = parseDeathDate(death);
  if (!b.year || !d.year) return "";
  var age = parseInt(d.year) - parseInt(b.year);
  if (age < 0) return "";
  if (d.month && b.month) {
    if (parseInt(d.month) < parseInt(b.month)) age--;
    else if (parseInt(d.month) === parseInt(b.month) && d.day && b.day && parseInt(d.day) < parseInt(b.day)) age--;
  }
  return age + "岁";
}

// ===== KINSHIP ENGINE =====
var ANC_M = ['','父亲','祖父','曾祖父','高祖父','天祖父','烈祖父','太祖父','远祖父','鼻祖父'];
var ANC_F = ['','母亲','祖母','曾祖母','高祖母','天祖母','烈祖母','太祖母','远祖母','鼻祖母'];
var DESC_M = ['','儿子','孙子','曾孙','玄孙','来孙','晜孙','仍孙','云孙','耳孙'];
var DESC_F = ['','女儿','孙女','曾孙女','玄孙女','来孙女','晜孙女','仍孙女','云孙女','耳孙女'];
var GEN_PREFIX = ['','','','曾','高','天','烈','太','远','鼻'];
var GEN_NAMES = {1:'承',2:'书',3:'礼',4:'乐',5:'永',6:'锦学'};
function displayGen(gen) {
  var base = parseInt(config.genBase) || 1;
  return gen + base - 1;
}
function formatGen(gen, mode) {
  var dg = displayGen(gen);
  var name = GEN_NAMES[gen];
  if (!name) return '第'+dg+'世';
  if (mode==='short') return name;
  return name+'字辈 · 第'+dg+'世';
}

function getMember(id) { return members.find(function(x){return x.id===id;}); }

function getAncestorIds(memberId) {
  var path = [memberId], cur = memberId;
  while (cur) { var m = getMember(cur); if (!m || !m.parentId) break; path.push(m.parentId); cur = m.parentId; }
  return path;
}

function getBirthYear(m) {
  if (!m || !m.birth) return null;
  var d = parseBirthDate(m.birth);
  return d.year ? parseInt(d.year) : null;
}

function cmpAge(a, b) {
  var ay = getBirthYear(a), by = getBirthYear(b);
  if (ay===null||by===null) return null;
  if (ay < by) return 'older';
  if (ay > by) return 'younger';
  // Same year — compare month and day
  var da = parseBirthDate(a.birth), db = parseBirthDate(b.birth);
  var am = da.month ? parseInt(da.month) : 0;
  var bm = db.month ? parseInt(db.month) : 0;
  if (am && bm && am !== bm) return am < bm ? 'older' : 'younger';
  var ad = da.day ? parseInt(da.day) : 0;
  var bd = db.day ? parseInt(db.day) : 0;
  if (ad && bd && ad !== bd) return ad < bd ? 'older' : 'younger';
  return 'same';
}

function getKinshipTerm(meId, targetId) {
  if (meId === targetId) return '我自己';
  var me = getMember(meId), target = getMember(targetId);
  if (!me || !target) return '';

  var pathMe = getAncestorIds(meId), pathTarget = getAncestorIds(targetId);

  // 1. target is my direct ancestor
  var idxT = pathMe.indexOf(targetId);
  if (idxT >= 0) {
    if (idxT > 9) return '';
    return (target.gender==='女' ? ANC_F : ANC_M)[idxT] || '';
  }

  // 2. target is my direct descendant
  var idxM = pathTarget.indexOf(meId);
  if (idxM >= 0) {
    if (idxM > 9) return '';
    return (target.gender==='女' ? DESC_F : DESC_M)[idxM] || '';
  }

  // 3. Collateral — find common ancestor
  var tIdx = {}; pathTarget.forEach(function(id,i){ tIdx[id]=i; });
  var dMe=-1, dT=-1, cId=null;
  for (var i=0;i<pathMe.length;i++) {
    if (pathMe[i] in tIdx) { dMe=i; dT=tIdx[pathMe[i]]; cId=pathMe[i]; break; }
  }
  if (dMe>=0 && cId!==null && dMe<=9 && dT<=9) {
    return calcCollateral(dMe, dT, me, target, pathMe, pathTarget, cId);
  }

  // 4. Spouse connections — no blood common ancestor found
  return getSpouseTerm(meId, targetId, me, target, pathMe);
}

function calcCollateral(dMe, dT, me, target, pathMe, pathTarget, cId) {
  if (dMe===1 && dT===1) return getSibTerm(me, target);

  if (dMe===2 && dT===1) {
    var parent = getMember(pathMe[1]);
    return getUncleAuntTerm(target, parent);
  }

  if (dMe===1 && dT===2) {
    return getNephTerm(target, me);
  }

  // 堂/表 determination:
  // 堂 = common ancestor is on paternal side (my path all male)
  //      AND the first generation below common ancestor on target's side is a son (male).
  // This means 堂姐's children are still 堂 (堂姐 is a son's daughter).
  // 姑姑's children are 表 (姑姑 is a daughter directly below the common ancestor).
  // Also handles 入赘: a female head of household can pass the 堂 lineage.
  var isTang = isPureMalePath(pathMe,1,dMe) && getMember(pathTarget[dT-1]) && getMember(pathTarget[dT-1]).gender==='男';

  // Same generation: cousins
  if (dMe===dT) {
    return getCousinTerm(me, target, isTang?'堂':'表');
  }

  // dMe > dT: target is higher generation
  if (dMe > dT) {
    var up = dMe - dT;
    // dT=1: target IS the common ancestor's direct child (grandparent's sibling, etc.)
    if (dT===1) {
      return getGrandUncleAunt(target, getMember(pathMe[dMe-1]), dMe);
    }
    // dT>=2, up=1: target's parent is common ancestor's child (parent's cousin = one gen above)
    if (up===1) {
      return getCousinParentTerm(target, me, isTang?'堂':'表');
    }
    // dT>=2, up>=2: deeper generational gap through collateral
    if (dMe<=9) {
      var lvlM = ['','','','曾','高','天','烈','太','远','鼻'];
      var genLvl = lvlM[up]||'';
      if (target.gender==='女') {
        return (isTang?'堂':'表')+genLvl+'姑婆';
      }
      var ageUp = cmpAge(target, me);
      var preUp = ageUp==='older'?'伯':(ageUp==='younger'?'叔':'');
      if (!preUp) { preUp = '族'; }
      return (isTang?'堂':'表')+(preUp||'')+genLvl+'祖父';
    }
    return '';
  }

  // dMe < dT: target is lower generation
  if (dMe < dT) {
    var down = dT - dMe;
    var prefixDN = ['','','','曾','高','天','烈','太','远','鼻'];

    if (dMe===1) {
      // Direct sibling's descendant line
      var baseN = getNephTerm(target, me);
      if (down===1) return baseN;
      // down>=2: sibling's grandchild = 侄孙/侄孙女
      var root = baseN.replace(/[子女]$/,'');
      return (prefixDN[down]||'')+root+'孙';
    }

    // dMe>=2: collateral younger line
    var baseN2 = getNephTerm(target, me);
    var root2 = baseN2.replace(/[子女]$/,'');
    if (down===1) return (isTang?'堂':'表')+baseN2;
    return (isTang?'堂':'表')+(prefixDN[down]||'')+root2+'孙';
  }

  return '';
}

function isPureMalePath(path, fromIdx, toIdx) {
  for (var i=fromIdx; i<toIdx; i++) {
    var m = getMember(path[i]); if (m && m.gender==='女') return false;
  }
  return true;
}

function getSibTerm(me, target) {
  var age = cmpAge(target, me);
  if (target.gender==='女') {
    if (age==='older') return '姐姐';
    if (age==='younger') return '妹妹';
    return '姐妹';
  }
  if (age==='older') return '哥哥';
  if (age==='younger') return '弟弟';
  return '兄弟';
}

function getUncleAuntTerm(target, parent) {
  if (target.gender==='女') return '姑姑';
  var age = cmpAge(target, parent);
  if (age==='older') return '伯伯';
  if (age==='younger') return '叔叔';
  return '叔伯';
}

function getCousinTerm(me, target, prefix) {
  var age = cmpAge(target, me);
  var sfx;
  if (target.gender==='女') {
    if (age==='older') sfx='姐'; else if (age==='younger') sfx='妹'; else sfx='姐妹';
  } else {
    if (age==='older') sfx='哥'; else if (age==='younger') sfx='弟'; else sfx='兄弟';
  }
  return prefix + sfx;
}

function getNephTerm(target, me) {
  if (me.gender==='女') return target.gender==='女' ? '外甥女' : '外甥';
  return target.gender==='女' ? '侄女' : '侄子';
}

function getGrandUncleAunt(target, myAnc, dMe) {
  var tLvl = dMe - 1; // target is one generation below common ancestor
  var age = cmpAge(target, myAnc);
  if (age === null) { age = cmpAgeBySiblings(target, myAnc); }
  var pre = age==='older'?'伯':(age==='younger'?'叔':'');
  if (!pre) { pre = '族'; }  // cannot determine elder/younger, use generic clan prefix
  if (target.gender==='女') {
    if (tLvl===2) return '姑奶奶';
    if (tLvl>=3) return (GEN_PREFIX[tLvl]||'')+'姑奶奶';
    return '姑奶奶';
  }
  if (tLvl===2) return (pre||'')+'祖父';
  if (tLvl>=3) return (pre||'')+(GEN_PREFIX[tLvl]||'')+'祖父';
  return (pre||'')+'祖父';
}
function cmpAgeBySiblings(a, b) {
  if (!a.parentId || !b.parentId || a.parentId !== b.parentId) return null;
  var sibs = members.filter(function(x){return x.parentId === a.parentId;});
  var years = [];
  sibs.forEach(function(s){
    var y = getBirthYear(s);
    if (y !== null) years.push({id:s.id, year:y});
  });
  years.sort(function(x,y){return x.year - y.year;});
  var posA = -1, posB = -1;
  for (var i=0; i<years.length; i++) {
    if (years[i].id === a.id) posA = i;
    if (years[i].id === b.id) posB = i;
  }
  if (posA>=0 && posB>=0) {
    return posA < posB ? 'older' : (posA > posB ? 'younger' : 'same');
  }
  return null;
}

function getCousinParentTerm(target, me, prefix) {
  var age = cmpAge(target, me);
  if (target.gender==='女') return prefix+'姑';
  if (age==='older') return prefix+'伯父';
  if (age==='younger') return prefix+'叔父';
  return prefix+'叔伯';
}

// ===== SPOUSE TERMS =====
function getSpouseTerm(meId, targetId, me, target, pathMe) {
  // 1. Direct spouse
  if (target.spouseOfId === meId || me.spouseOfId === targetId) {
    return target.gender==='女'?'妻子':'丈夫';
  }

  // 2. Target is spouse of my ancestor → (great-)grandmother etc.
  if (target.spouseOfId) {
    var hubIdx = pathMe.indexOf(target.spouseOfId);
    if (hubIdx >= 1 && hubIdx <= 9) {
      if (target.gender==='女') return ANC_F[hubIdx]||'';
      return ANC_M[hubIdx]||'';
    }
  }
  // Target is husband of my female ancestor (via spouseOfId on ancestor)
  for (var i=1; i<pathMe.length && i<=9; i++) {
    var anc = getMember(pathMe[i]);
    if (anc && anc.gender==='女' && anc.spouseOfId === targetId) {
      return ANC_M[i]||'';
    }
  }

  // 3. Target is spouse of my blood relative
  var bloodRelId = target.spouseOfId;
  if (!bloodRelId) {
    var wife = members.find(function(x){return x.spouseOfId===targetId;});
    if (wife) bloodRelId = wife.id;
  }
  if (bloodRelId && bloodRelId !== meId) {
    var bloodTerm = getKinshipTermCore(meId, bloodRelId);
    if (bloodTerm && bloodTerm!=='我自己') {
      return spouseOfBloodRelative(bloodTerm, target, getMember(bloodRelId), me);
    }
  }

  // 4. Target is blood relative of my spouse (in-law) — try all spouses
  var myAllSpouses = getMyAllSpouses(meId);
  for (var si = 0; si < myAllSpouses.length; si++) {
    var mySpouse = myAllSpouses[si];
    if (mySpouse && mySpouse.id !== targetId) {
      var termFromSp = getKinshipTermCore(mySpouse.id, targetId);
      if (termFromSp && termFromSp!=='我自己') {
        // If target is a descendant of my spouse, they're my descendant too — use blood term directly
        if (getAncestorIds(targetId).indexOf(mySpouse.id) >= 0) {
          return termFromSp;
        }
        return inLawConvert(termFromSp, me);
      }
    }
  }

  return '';
}

// Blood-only version — no spouse recursion
function getKinshipTermCore(aId, bId) {
  if (aId === bId) return '我自己';
  var a = getMember(aId), b = getMember(bId);
  if (!a || !b) return '';
  var pA = getAncestorIds(aId), pB = getAncestorIds(bId);
  var idxB = pA.indexOf(bId);
  if (idxB >= 0) { if (idxB>9) return ''; return (b.gender==='女'?ANC_F:ANC_M)[idxB]||''; }
  var idxA = pB.indexOf(aId);
  if (idxA >= 0) { if (idxA>9) return ''; return (b.gender==='女'?DESC_F:DESC_M)[idxA]||''; }
  var tIdx = {}; pB.forEach(function(id,i){tIdx[id]=i;});
  var dA=-1, dB=-1, cId=null;
  for (var i=0;i<pA.length;i++) { if (pA[i] in tIdx) { dA=i; dB=tIdx[pA[i]]; cId=pA[i]; break; } }
  if (dA>=0 && cId!==null && dA<=9 && dB<=9) {
    return calcCollateral(dA, dB, a, b, pA, pB, cId);
  }
  return '';
}

function getMySpouse(meId) {
  var me = getMember(meId);
  if (me.spouseOfId) return getMember(me.spouseOfId);
  return members.find(function(x){return x.spouseOfId===meId;}) || null;
}
function getMyAllSpouses(meId) {
  var list = [];
  var me = getMember(meId);
  if (me && me.spouseOfId) {
    var sp = getMember(me.spouseOfId);
    if (sp) list.push(sp);
  }
  var spousesOfMe = members.filter(function(x){return x.spouseOfId===meId;});
  list = list.concat(spousesOfMe);
  return list;
}

function spouseOfBloodRelative(bloodTerm, target, bloodRel, me) {
  if (bloodTerm==='哥哥') return target.gender==='女'?'嫂子':'姐夫';
  if (bloodTerm==='弟弟') return target.gender==='女'?'弟媳':'妹夫';
  if (bloodTerm==='姐姐') return target.gender==='女'?'姨姐':'姐夫';
  if (bloodTerm==='妹妹') return target.gender==='女'?'姨妹':'妹夫';
  if (bloodTerm==='兄弟') return target.gender==='女'?'嫂/弟媳':'姐/妹夫';
  if (bloodTerm==='姐妹') return target.gender==='女'?'嫂/弟媳':'姐/妹夫';
  if (bloodTerm==='伯伯') return target.gender==='女'?'伯母':'伯父';
  if (bloodTerm==='叔叔') return target.gender==='女'?'婶婶':'叔父';
  if (bloodTerm==='姑姑') return target.gender==='女'?'姑母':'姑父';
  if (bloodTerm==='叔伯') return target.gender==='女'?'婶/伯母':'姑/姨父';
  if (bloodTerm==='舅舅') return target.gender==='女'?'舅妈':'舅父';
  if (bloodTerm==='姨妈') return target.gender==='女'?'姨妈':'姨父';
  // Cousin's spouse: extract prefix (堂/表) and add spouse suffix
  var age = cmpAge(target, me);
  var pref = bloodTerm.replace(/[兄妹弟姐袍].*$/,'');
  if (pref==='堂'||pref==='表') {
    return target.gender==='女' ? pref+(age==='older'?'嫂':(age==='younger'?'弟媳':'嫂/弟媳'))
                               : pref+(age==='older'?'姐夫':(age==='younger'?'妹夫':'姐/妹夫'));
  }
  // Generic fallback
  return target.gender==='女' ? (bloodTerm+'之妻') : (bloodTerm+'之夫');
}

function inLawConvert(termFromSpouse, me) {
  var imMale = me.gender==='男';
  // Direct parents
  if (termFromSpouse==='父亲'||termFromSpouse==='父') return imMale?'岳父':'公公';
  if (termFromSpouse==='母亲'||termFromSpouse==='母') return imMale?'岳母':'婆婆';
  // Grandparents (blood terms for generation 2+)
  if (termFromSpouse==='祖父') return imMale?'岳祖父':'公祖父';
  if (termFromSpouse==='祖母') return imMale?'岳祖母':'公祖母';
  // Higher ancestors — use 岳/公 prefix
  if (/^(曾|高|天|烈|太|远|鼻)?(祖父|祖母)$/.test(termFromSpouse)) {
    return (imMale?'岳':'公')+termFromSpouse;
  }
  // Siblings
  if (termFromSpouse==='哥哥') return imMale?'大舅子':'大伯子';
  if (termFromSpouse==='弟弟') return imMale?'小舅子':'小叔子';
  if (termFromSpouse==='姐姐') return imMale?'大姨子':'大姑子';
  if (termFromSpouse==='妹妹') return imMale?'小姨子':'小姑子';
  if (termFromSpouse==='兄弟') return imMale?'舅子':'叔/伯子';
  if (termFromSpouse==='姐妹') return imMale?'姨子':'姑子';
  // Uncle/aunt
  if (termFromSpouse==='伯伯'||termFromSpouse==='叔叔'||termFromSpouse==='伯父'||termFromSpouse==='叔父') return imMale?'岳伯/岳叔':'公伯/公叔';
  if (termFromSpouse==='姑姑') return imMale?'岳姑':'公姑';
  if (termFromSpouse==='舅舅') return imMale?'岳舅':'公舅';
  if (termFromSpouse==='姨妈') return imMale?'岳姨':'公姨';
  // Nephew/niece
  if (termFromSpouse==='侄子'||termFromSpouse==='侄女') return imMale?'内'+termFromSpouse:'外'+termFromSpouse;
  // Descendants (children, grandchildren) — shared with spouse, no conversion needed
  // These shouldn't reach here due to check in getSpouseTerm, but safety net:
  if (termFromSpouse) return (imMale?'岳':'公')+termFromSpouse;
  return '';
}

