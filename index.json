.chat-bubble.own .chat-voice-player .voice-dur{color:rgba(255,255,255,.7)}
.chat-login-hint{font-size:.65rem;color:#999;text-align:center;padding:6px;flex-shrink:0}
.chat-date-sep{text-align:center;font-size:.65rem;color:#bbb;padding:8px 0;margin:4px 0}


