// ===== MUSIC =====
var htmlAudio = null;
function ensureHtmlAudio() {
  if (!htmlAudio) { htmlAudio = new Audio(); htmlAudio.loop = true; htmlAudio.preload = 'auto'; }
  return htmlAudio;
}
function syncMusicState() {
  var cfg = JSON.parse(localStorage.getItem('ft_config')||'{}');
  var btn = document.getElementById('music-btn');
  if (cfg.musicEnabled !== false) {
    if (btn) { btn.classList.remove('off'); btn.textContent = '🎵'; }
    if (window.Android) {
      Android.playMusic(cfg.musicUrl||'');
    } else {
      var a = ensureHtmlAudio();
      var targetUrl = cfg.musicUrl||'';
      if (a.src !== targetUrl && !a.src.endsWith(targetUrl)) {
        a.src = targetUrl;
      }
      if (a.paused) { a.play().catch(function(){}); }
    }
  } else {
    if (btn) { btn.classList.add('off'); btn.textContent = '🔇'; }
    if (window.Android) {
      Android.pauseMusic();
    } else {
      var a = ensureHtmlAudio(); a.pause();
    }
  }
}
function toggleMusic() {
  var cfg = JSON.parse(localStorage.getItem('ft_config')||'{}');
  cfg.musicEnabled = cfg.musicEnabled === false ? true : false;
  localStorage.setItem('ft_config', JSON.stringify(cfg));
  syncMusicState();
}
