// ===== NAV =====
function showPage(id) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  if (id === 'home') { setTimeout(function() { checkBirthdays(); }, 300); }
  document.querySelectorAll('.tab-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  var tab = document.querySelector('.tab-item[data-page="'+id+'"]');
  if(tab) tab.classList.add('active');
  if(id==='tree') {
    var savedMode = 'card';
    try { savedMode = localStorage.getItem('ft_tree_view') || 'card'; } catch(e) {}
    if (savedMode === 'tree') {
      document.getElementById('family-view').classList.remove('active');
      document.getElementById('tree-wrap').style.display = '';
      document.querySelectorAll('#tree-view-toggle button').forEach(function(b){b.classList.remove('active');});
      var treeBtns = document.querySelectorAll('#tree-view-toggle button');
      if (treeBtns[1]) treeBtns[1].classList.add('active');
      resetView();
      renderTree();
    } else {
      document.getElementById('family-view').classList.add('active');
      document.getElementById('tree-wrap').style.display = 'none';
      document.querySelectorAll('#tree-view-toggle button').forEach(function(b){b.classList.remove('active');});
      var cardBtns = document.querySelectorAll('#tree-view-toggle button');
      if (cardBtns[0]) cardBtns[0].classList.add('active');
      var personId = config.selfId || (getRoots()[0] ? getRoots()[0].id : null);
      if (personId) renderFamilyView(personId);
      else document.getElementById('family-cards').innerHTML = '<div class="family-empty">暂无族人数据。请在管理模式下点击「添加始祖」开始建立族谱。</div>';
    }
    updateSelfDisplay();
  }
  if(id==='members') renderMembers();
  if(id==='stories') renderStories();
  if(id==='home') updateHomeStats();
}

