// ===== STORIES =====
function renderStories() {
  const grid = document.getElementById('stories-grid');
  if(stories.length===0) { grid.innerHTML='<div style="color:var(--text-light);font-size:.9rem;padding:20px">暂无故事，点击「添加故事」开始记录。</div>'; return; }
  grid.innerHTML = stories.map(s=>`
    <div class="story-card">
      <div class="story-img">${s.photo ? `<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="${s.photo}" alt="${s.title}">` : (s.icon||'📖')}</div>
      <div class="story-body">
        <div class="story-title">${s.title}</div>
        <div class="story-date">${s.date||''}</div>
        <div class="story-desc">${s.desc||''}</div>
      </div>
      <div class="story-actions">
        <button class="btn btn-accent btn-sm" onclick="openStoryForm(${s.id})">编辑</button>
        <button class="btn btn-danger btn-sm" onclick="deleteStory(${s.id})">删除</button>
      </div>
    </div>`).join('');
}
function openStoryForm(id) {
  document.getElementById('story-form-title').textContent = id ? '编辑故事' : '添加故事';
  document.getElementById('sf-id').value = id||'';
  setStoryPhotoPreview(null);
  if(id) {
    const s = stories.find(x=>x.id===id); if(!s) return;
    document.getElementById('sf-title').value=s.title;
    document.getElementById('sf-date').value=s.date||'';
    document.getElementById('sf-icon').value=s.icon||'';
    document.getElementById('sf-desc').value=s.desc||'';
    if(s.photo) setStoryPhotoPreview(s.photo);
  } else {
    document.getElementById('sf-title').value='';
    document.getElementById('sf-date').value='';
    document.getElementById('sf-icon').value='';
    document.getElementById('sf-desc').value='';
  }
  openModal('story-form-modal');
}
function saveStory() {
  const title = document.getElementById('sf-title').value.trim();
  if(!title) { showToast('请输入标题','error'); return; }
  const id = parseInt(document.getElementById('sf-id').value)||0;
  const preview = document.getElementById('sf-photo-preview');
  const photo = (preview.style.display!=='none' && preview.src && preview.src !== window.location.href) ? preview.src : null;
  const data = {
    title, date:document.getElementById('sf-date').value,
    icon:document.getElementById('sf-icon').value||'📖',
    desc:document.getElementById('sf-desc').value,
    photo
  };
  if(id) { const i=stories.findIndex(x=>x.id===id); if(i>=0){stories[i]={...stories[i],...data};} }
  else { data.id=nextStoryId++; stories.push(data); }
  saveData('ft_stories',stories);
  closeModal('story-form-modal');
  renderStories();
  showToast(id?'已更新故事':'已添加故事','success');
}
async function deleteStory(id) {
  const s = stories.find(x=>x.id===id); if(!s) return;
  const ok = await showConfirm('删除故事',`确定要删除「${s.title}」吗？`);
  if(!ok) return;
  stories = stories.filter(x=>x.id!==id);
  saveData('ft_stories',stories);
  renderStories();
  showToast('已删除');
}

// ===== ALBUM =====
let lightboxIndex = 0;
let lightboxAlbum = []; // current album array for lightbox nav

function getAlbum(memberId) {
  const m = members.find(x => x.id === memberId);
  if(!m) return [];
  return m.album || [];
}

function openAlbum() {
  const memberId = parseInt(document.getElementById('album-modal').dataset.memberId);
  const m = members.find(x => x.id === memberId);
  if(!m) return;
  document.getElementById('album-title').textContent = m.name + ' 的相册';
  renderAlbumGrid(memberId);
  openModal('album-modal');
}

function renderAlbumGrid(memberId) {
  const album = getAlbum(memberId);
  lightboxAlbum = album;
  const grid = document.getElementById('album-grid');
  const count = document.getElementById('album-count');
  count.textContent = album.length ? album.length + ' 张照片' : '暂无照片';

  grid.innerHTML = '';

  // Add-photo card (admin only, via CSS)
  const addCard = document.createElement('div');
  addCard.className = 'album-add-card';
  addCard.innerHTML = '<div style="font-size:1.6rem">📷</div><div>添加照片</div>';
  addCard.onclick = () => document.getElementById('album-file-input').click();
  document.getElementById('album-file-input').dataset.memberId = memberId;
  grid.appendChild(addCard);

  if(album.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'album-empty';
    empty.textContent = '暂无照片';
    grid.appendChild(empty);
    return;
  }

  album.forEach((item, idx) => {
    const wrap = document.createElement('div');
    wrap.className = 'album-item';

    const img = document.createElement('img');
    img.src = item.url;
    img.alt = item.caption || '';
    img.onclick = () => openLightbox(idx);
    wrap.appendChild(img);

    if(item.caption) {
      const cap = document.createElement('div');
      cap.className = 'album-caption';
      cap.textContent = item.caption;
      wrap.appendChild(cap);
    }

    // Delete button (admin)
    const delBtn = document.createElement('button');
    delBtn.className = 'album-del-btn';
    delBtn.title = '删除';
    delBtn.textContent = '✕';
    delBtn.onclick = (e) => { e.stopPropagation(); deleteAlbumPhoto(memberId, idx); };
    wrap.appendChild(delBtn);

    // Caption edit (admin) — shown below image
    if(isAdmin) {
      const capInput = document.createElement('input');
      capInput.className = 'caption-edit-input';
      capInput.placeholder = '添加说明…';
      capInput.value = item.caption || '';
      capInput.style.cssText = 'position:absolute;bottom:0;left:0;right:0;border-radius:0 0 10px 10px;border:none;border-top:1px solid var(--border);font-size:.7rem;padding:3px 6px;background:rgba(255,255,255,.92);display:none;';
      capInput.onclick = e => e.stopPropagation();
      capInput.onblur = () => {
        saveAlbumCaption(memberId, idx, capInput.value.trim());
        capInput.style.display = 'none';
      };
      capInput.onkeydown = e => { if(e.key === 'Enter') capInput.blur(); };
      wrap.appendChild(capInput);

      // Long-press / right-click to edit caption
      wrap.addEventListener('contextmenu', e => {
        e.preventDefault();
        capInput.style.display = 'block';
        capInput.focus();
      });
      // Touch long-press
      let pressTimer;
      wrap.addEventListener('touchstart', () => { pressTimer = setTimeout(() => { capInput.style.display = 'block'; capInput.focus(); }, 600); }, {passive:true});
      wrap.addEventListener('touchend', () => clearTimeout(pressTimer), {passive:true});
      wrap.addEventListener('touchmove', () => clearTimeout(pressTimer), {passive:true});
    }

    grid.appendChild(wrap);
  });
}

function handleAlbumUpload(e) {
  const memberId = parseInt(e.target.dataset.memberId);
  const files = Array.from(e.target.files);
  if(!files.length) return;
  let loaded = 0;
  files.forEach(file => {
    if(file.size > 5 * 1024 * 1024) { showToast('单张图片不能超过 5MB', 'error'); return; }
    compressImage(file, function(dataUrl) {
      const m = members.find(x => x.id === memberId);
      if(!m) return;
      if(!m.album) m.album = [];
      m.album.push({ url: dataUrl, caption: '' });
      loaded++;
      if(loaded === files.length) {
        saveData('ft_members', members);
        renderAlbumGrid(memberId);
        showToast('已添加 ' + loaded + ' 张照片', 'success');
      }
    });
  });
  e.target.value = '';
}
function deleteAlbumPhoto(memberId, idx) {
  const m = members.find(x => x.id === memberId);
  if(!m || !m.album) return;
  m.album.splice(idx, 1);
  saveData('ft_members', members);
  renderAlbumGrid(memberId);
  showToast('已删除');
}

function saveAlbumCaption(memberId, idx, caption) {
  const m = members.find(x => x.id === memberId);
  if(!m || !m.album || !m.album[idx]) return;
  m.album[idx].caption = caption;
  saveData('ft_members', members);
  renderAlbumGrid(memberId);
}

