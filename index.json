.lock-hint{font-size:13px;color:#999;margin-top:16px}
.lock-error{font-size:13px;color:#c0392b;margin-top:8px;display:none}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}50%{transform:translateX(8px)}75%{transform:translateX(-4px)}}
.hidden-input{position:absolute;opacity:0;width:100%;height:56px;left:0;top:0;font-size:32px;letter-spacing:40px;text-indent:12px}

.bday-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center}
