let treeTx = 40, treeTy = 40; // translation (px)
let isPanning = false;
let panStartX = 0, panStartY = 0;

function applyTreeTransform(animate) {
  const wrap = document.getElementById('tree-scale-wrap');
  wrap.style.transition = animate ? 'transform .25s ease' : 'none';
  wrap.style.transform = `translate(${treeTx}px,${treeTy}px) scale(${treeScale})`;
}

function isInSearchArea(el) {
  while (el) {
    if (el.classList && el.classList.contains('tree-search-wrap')) return true;
    el = el.parentElement;
  }
  return false;
}

function resetView() {
  autoFitTree();
}

function autoFitTree() {
  var wrap = document.getElementById('tree-wrap');
  var scaleWrap = document.getElementById('tree-scale-wrap');
  var container = document.getElementById('tree-container');
  if (!wrap || !scaleWrap || !container) return;
  if (!container.children.length) return;

  // Temporarily reset transform to measure natural layout
  var prevTrans = scaleWrap.style.transform;
  var prevTransn = scaleWrap.style.transition;
  scaleWrap.style.transition = 'none';
  scaleWrap.style.transform = '';

  var wrapW = wrap.clientWidth;
  var wrapH = wrap.clientHeight;
  var contRect = container.getBoundingClientRect();
  var swRect = scaleWrap.getBoundingClientRect();
  var contW = contRect.width;
  var contH = contRect.height;
  var contLeft = contRect.left - swRect.left;
  var contTop = contRect.top - swRect.top;

  // Restore
  scaleWrap.style.transition = prevTransn;
  scaleWrap.style.transform = prevTrans;

  if (contW < 10 || contH < 10) return;

  var pad = 40;
  var availW = wrapW - pad * 2;
  var availH = wrapH - pad * 2;
  var fitScale = Math.min(availW / contW, availH / contH, 2.0);
  fitScale = Math.max(0.08, fitScale);

  var scaledW = contW * fitScale;
  var scaledH = contH * fitScale;
  treeTx = (wrapW - scaledW) / 2 - contLeft * fitScale;
  treeTy = (wrapH - scaledH) / 2 - contTop * fitScale;
  treeScale = fitScale;
  applyTreeTransform(true);
}

function initTreeInteraction() {
  const wrap = document.getElementById('tree-wrap');
  if(!wrap) return;

  // ---- Mouse wheel zoom (desktop) ----
  wrap.addEventListener('wheel', e => {
    e.preventDefault();
    const rect = wrap.getBoundingClientRect();
    // Mouse position relative to wrap
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const delta = e.deltaY < 0 ? 1.1 : 0.909;
    const newScale = Math.min(3, Math.max(0.08, treeScale * delta));
    // Adjust translation so zoom is centered on mouse
    treeTx = mx - (mx - treeTx) * (newScale / treeScale);
    treeTy = my - (my - treeTy) * (newScale / treeScale);
    treeScale = newScale;
    applyTreeTransform(false);
  }, {passive: false});

  // ---- Mouse drag pan (desktop) ----
  let panMoved = false;
  wrap.addEventListener('mousedown', e => {
    if(e.button !== 0) return;
    if(isInSearchArea(e.target)) return;
    isPanning = true;
    panMoved = false;
    panStartX = e.clientX - treeTx;
    panStartY = e.clientY - treeTy;
    wrap.classList.add('grabbing');
  });
  window.addEventListener('mousemove', e => {
    if(!isPanning) return;
    const nx = e.clientX - panStartX;
    const ny = e.clientY - panStartY;
    if(Math.abs(nx - treeTx) > 3 || Math.abs(ny - treeTy) > 3) panMoved = true;
    treeTx = nx;
    treeTy = ny;
    applyTreeTransform(false);
  });
  window.addEventListener('mouseup', () => {
    if(!isPanning) return;
    isPanning = false;
    wrap.classList.remove('grabbing');
    if(panMoved) {
      // Block the next click event on any child element
      wrap._blockNextClick = true;
      setTimeout(() => { wrap._blockNextClick = false; }, 50);
    }
  });
  // Intercept clicks that follow a drag
  wrap.addEventListener('click', e => {
    if(isInSearchArea(e.target)) return;
    if(wrap._blockNextClick) { e.stopPropagation(); e.preventDefault(); }
  }, true);

  // ---- Touch: single finger pan, two finger pinch zoom (mobile) ----
  let lastTouches = null;
  let pinchStartDist = 0;
  let pinchStartScale = 1;
  let pinchMidX = 0, pinchMidY = 0;
  let pinchStartTx = 0, pinchStartTy = 0;
  let touchMoved = false;
  let touchStartX = 0, touchStartY = 0;

  wrap.addEventListener('touchstart', e => {
    if(isInSearchArea(e.target)) return;
    e.preventDefault();
    window._isTouchDevice = true;
    document.body.classList.add('touch-device'); // enables always-on admin btns
    lastTouches = e.touches;
    touchMoved = false;
    if(e.touches.length === 1) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }
    if(e.touches.length === 2) {
      const t0 = e.touches[0], t1 = e.touches[1];
      pinchStartDist = Math.hypot(t1.clientX - t0.clientX, t1.clientY - t0.clientY);
      pinchStartScale = treeScale;
      const rect = wrap.getBoundingClientRect();
      pinchMidX = (t0.clientX + t1.clientX) / 2 - rect.left;
      pinchMidY = (t0.clientY + t1.clientY) / 2 - rect.top;
      pinchStartTx = treeTx;
      pinchStartTy = treeTy;
    }
  }, {passive: false});

  wrap.addEventListener('touchmove', e => {
    e.preventDefault();
    if(e.touches.length === 1 && lastTouches && lastTouches.length === 1) {
      const dx = e.touches[0].clientX - lastTouches[0].clientX;
      const dy = e.touches[0].clientY - lastTouches[0].clientY;
      // Mark as moved if displacement > 5px
      if(Math.abs(e.touches[0].clientX - touchStartX) > 5 ||
         Math.abs(e.touches[0].clientY - touchStartY) > 5) touchMoved = true;
      treeTx += dx;
      treeTy += dy;
      applyTreeTransform(false);
    } else if(e.touches.length === 2) {
      touchMoved = true;
      const t0 = e.touches[0], t1 = e.touches[1];
      const dist = Math.hypot(t1.clientX - t0.clientX, t1.clientY - t0.clientY);
      const newScale = Math.min(3, Math.max(0.08, pinchStartScale * (dist / pinchStartDist)));
      treeTx = pinchMidX - (pinchMidX - pinchStartTx) * (newScale / pinchStartScale);
      treeTy = pinchMidY - (pinchMidY - pinchStartTy) * (newScale / pinchStartScale);
      treeScale = newScale;
      applyTreeTransform(false);
    }
    lastTouches = e.touches;
  }, {passive: false});

  wrap.addEventListener('touchend', e => {
    if(e.changedTouches.length === 1 && e.touches.length === 0 && !touchMoved) {
      const target = e.changedTouches[0].target;

      // 1. Admin action buttons (edit / delete) — single tap
      const adminBtn = target.closest('.node-btn');
      if(adminBtn) {
        adminBtn.click();
        lastTapTime = 0; lastTapTarget = null;
        lastTouches = e.touches;
        return;
      }

      // 2. Add-child / add-spouse buttons — single tap
      const addBtn = target.closest('[data-add-btn]');
      if(addBtn) {
        addBtn.click();
        lastTapTime = 0; lastTapTarget = null;
        lastTouches = e.touches;
        return;
      }

      // 3. Regular node — single tap to open detail
      const node = target.closest('.t-node:not([data-add-btn])');
      if(node) {
        const clickEvt = new MouseEvent('click', {bubbles: true, cancelable: true});
        clickEvt._fromDoubleTap = true;
        node.dispatchEvent(clickEvt);
      }
    }
    lastTouches = e.touches;
  }, {passive: false});
}

// ===== TREE RENDER =====
// Build a proper branching tree:
// - Root nodes: members with parentId=null and spouseOfId=null
// - Each node may have children (members whose parentId = this node's id)
// - Each node may have a spouse (member whose spouseOfId = this node's id)
// - Spouses are shown beside the node with "＝" connector, no branch

function getChildren(parentId) {
  return members.filter(m => m.parentId === parentId && !m.spouseOfId);
}
function getSpouses(memberId) {
  return members.filter(m => m.spouseOfId === memberId);
}
function getSpouse(memberId) {
  return members.find(m => m.spouseOfId === memberId) || null;
}
function getParents(personId) {
  var m = getMember(personId);
  if (!m || !m.parentId) return {father:null,mother:null};
  var father = getMember(m.parentId);
  var mother = father ? getSpouse(father.id) : null;
  return {father:father||null, mother:mother||null};
}
function buildAncestryPath(personId) {
  var ids = getAncestorIds(personId);
  var path = [];
  for (var i = ids.length - 1; i >= 0; i--) {
    var m = getMember(ids[i]);
    if (m) path.push(m);
  }
  return path;
}
function getRoots() {
  return members.filter(m => !m.parentId && !m.spouseOfId);
}

function makeNodeEl(m, genNum) {
  const div = document.createElement('div');
  div.className = 't-node gen-' + Math.min(genNum, 5);
  div.dataset.memberId = m.id;
  var selfIdForTitle = config.selfId || null;
  var kinTitle = '';
  if (selfIdForTitle && m.id === selfIdForTitle) { kinTitle = ' · ⭐我'; }
  else if (selfIdForTitle) { var kt = getKinshipTerm(selfIdForTitle, m.id); if (kt) kinTitle = ' · 我的'+kt; }
  div.title = m.name + kinTitle + ' · ' + formatGen(genNum,'short');

  // Admin buttons
  const adminBtns = document.createElement('div');
  adminBtns.className = 'node-admin-btns';
  adminBtns.innerHTML =
    '<button class="node-btn node-btn-edit" title="编辑" onclick="event.stopPropagation();openMemberForm('+m.id+',null,\'edit\')">✎</button>' +
    '<button class="node-btn node-btn-del" title="删除" onclick="event.stopPropagation();deleteMember('+m.id+')">✕</button>';
  div.appendChild(adminBtns);

  const av = document.createElement('div');
  av.className = 't-av';
  if(m.photo) { av.innerHTML = '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="'+m.photo+'" alt="'+m.name+'">'; }
  else { av.textContent = m.name[0]; }
  div.appendChild(av);

  const name = document.createElement('div');
  name.className = 't-name';
  name.textContent = m.name;
  div.appendChild(name);

  const role = document.createElement('div');
  role.className = 't-role';
  if (selfIdForTitle && m.id === selfIdForTitle) {
    role.textContent = '⭐ 我';
    role.style.color = 'var(--accent)';
    role.style.fontWeight = 'bold';
  } else if (selfIdForTitle) {
    var kTerm = getKinshipTerm(selfIdForTitle, m.id);
    role.textContent = kTerm ? '我的'+kTerm : formatGen(genNum,'short');
  } else {
    role.textContent = formatGen(genNum,'short');
  }
  div.appendChild(role);

  // Desktop: single click. Mobile: double-tap (handled in touch layer)
  div.addEventListener('click', e => {
    if(selectingSelf && handleSelfNodeClick(m.id)) return;
    if(e._fromDoubleTap) { openMemberDetail(m.id); return; }
    if(!window._isTouchDevice) openMemberDetail(m.id);
  });
  return div;
}

function makeSpouseEl(spouse, genNum) {
  const div = makeNodeEl(spouse, genNum);
  div.classList.add('spouse');
  return div;
}

function makeAddChildBtn(parentId) {
  const btn = document.createElement('div');
  btn.title = '添加子女';
  btn.dataset.addBtn = '1';
  btn.style.cssText = 'width:24px;height:24px;border-radius:50%;border:1px dashed var(--border);background:transparent;color:var(--text-light);font-size:1rem;display:none;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;margin-top:4px;transition:all .2s;';
  btn.textContent = '＋';
  if(isAdmin) btn.style.display = 'flex';
  btn.addEventListener('mouseenter', () => { btn.style.borderColor='var(--primary)'; btn.style.color='var(--primary)'; });
  btn.addEventListener('mouseleave', () => { btn.style.borderColor='var(--border)'; btn.style.color='var(--text-light)'; });
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    openMemberForm(null, parentId, 'child');
  });
  return btn;
}

function makeAddSpouseBtn(memberId) {
  const btn = document.createElement('div');
  btn.className = 't-node add-btn';
  btn.title = '添加配偶';
  btn.dataset.addBtn = '1';
  btn.style.cssText = 'width:28px;height:28px;font-size:1rem;border-radius:50%;display:none;align-items:center;justify-content:center;border:1px dashed var(--accent);color:var(--accent);background:transparent;cursor:pointer;flex-shrink:0;';
  btn.textContent = '♥';
  if(isAdmin) btn.style.display = 'flex';
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    openMemberForm(null, memberId, 'spouse');
  });
  return btn;
}

// Render a single branch rooted at member `m`
// Returns a DOM element representing the full subtree
function renderBranch(m) {
  const branch = document.createElement('div');
  branch.className = 'child-branch';
  branch.style.cssText = 'display:flex;flex-direction:column;align-items:center;';

  // --- Couple row (member + optional spouse) ---
  const coupleRow = document.createElement('div');
  coupleRow.className = 'couple-unit';
  coupleRow.style.cssText = 'display:flex;align-items:center;gap:4px;';

  const nodeEl = makeNodeEl(m, m.gen);
  coupleRow.appendChild(nodeEl);

  const spouses = getSpouses(m.id);
  spouses.forEach(function(spouse) {
    const connector = document.createElement('span');
    connector.className = 'spouse-connector';
    connector.textContent = '＝';
    coupleRow.appendChild(connector);
    coupleRow.appendChild(makeSpouseEl(spouse, m.gen));
  });
  // Always show add-spouse button in admin mode (supports multiple spouses)
  if (isAdmin) {
    const addSpouseBtn = makeAddSpouseBtn(m.id);
    coupleRow.appendChild(addSpouseBtn);
  }

  branch.appendChild(coupleRow);

  // Add-child button — always directly under the couple row, only once
  const addChildBtn = makeAddChildBtn(m.id);
  branch.appendChild(addChildBtn);

  // --- Children ---
  const children = getChildren(m.id);
  if(children.length === 0) return branch;

  // Vertical line down from parent node to horizontal bar
  const vDown = document.createElement('div');
  vDown.style.cssText = 'width:2px;height:16px;background:var(--border);margin:0 auto;';
  branch.appendChild(vDown);

  // Build child branches
  const childBranches = children.map(c => renderBranch(c));

  // Wrap each child with a vertical-line-up stub
  const childCols = childBranches.map(cb => {
    const col = document.createElement('div');
    col.style.cssText = 'display:flex;flex-direction:column;align-items:center;padding:0 10px;';
    const vUp = document.createElement('div');
    vUp.style.cssText = 'width:2px;height:16px;background:var(--border);margin:0 auto;';
    col.appendChild(vUp);
    col.appendChild(cb);
    return col;
  });

  // Horizontal line wrapper — line spans full width of children row
  const hLineWrap = document.createElement('div');
  hLineWrap.style.cssText = 'display:flex;flex-direction:column;align-items:stretch;';

  const hLine = document.createElement('div');
  hLine.style.cssText = 'height:2px;background:var(--border);';
  hLineWrap.appendChild(hLine);

  const colsRow = document.createElement('div');
  colsRow.style.cssText = 'display:flex;align-items:flex-start;justify-content:center;';
  childCols.forEach(c => colsRow.appendChild(c));
  hLineWrap.appendChild(colsRow);

  branch.appendChild(hLineWrap);
  return branch;
}

// ===== FAMILY CARD VIEW =====
var currentFamilyPerson = null;

function switchTreeView(mode) {
  var familyView = document.getElementById('family-view');
  var treeWrap = document.getElementById('tree-wrap');
  var toggleBtns = document.querySelectorAll('#tree-view-toggle button');
  toggleBtns.forEach(function(b){ b.classList.remove('active'); });
  if (mode === 'card') {
    familyView.classList.add('active');
    treeWrap.style.display = 'none';
    toggleBtns[0].classList.add('active');
    if (currentFamilyPerson) renderFamilyView(currentFamilyPerson);
  } else {
    familyView.classList.remove('active');
    treeWrap.style.display = '';
    toggleBtns[1].classList.add('active');
    resetView();
    renderTree();
  }
  try { localStorage.setItem('ft_tree_view', mode); } catch(e) {}
}

function refreshView() {
  var treeWrap = document.getElementById('tree-wrap');
  if (treeWrap && treeWrap.style.display === 'none') {
    if (currentFamilyPerson && getMember(currentFamilyPerson)) {
      renderFamilyView(currentFamilyPerson);
    } else {
      currentFamilyPerson = null;
      var root = getRoots()[0];
      if (root) renderFamilyView(root.id);
      else document.getElementById('family-cards').innerHTML = '<div class="family-empty">暂无族人数据。请在管理模式下点击「添加始祖」开始建立族谱。</div>';
    }
  } else {
    renderTree();
  }
}

function renderFamilyView(personId) {
  var person = getMember(personId);
  if (!person) return;
  currentFamilyPerson = personId;
  var container = document.getElementById('family-cards');
  var breadcrumb = document.getElementById('family-breadcrumb');

  // Breadcrumb
  var path = buildAncestryPath(personId);
  var crumbs = path.map(function(m, i){
    var isLast = i === path.length - 1;
    var cls = isLast ? 'breadcrumb-item current' : 'breadcrumb-item';
    var onclick = isLast ? '' : ' onclick="renderFamilyView(' + m.id + ')"';
    return '<span class="' + cls + '"' + onclick + '>' + m.name + '</span>';
  });
  breadcrumb.innerHTML = crumbs.join('<span class="breadcrumb-sep">›</span>');

  var selfId = config.selfId || null;
  var html = '';
  var parents = getParents(personId);

  // Parents section
  if (parents.father || parents.mother) {
    html += '<div class="family-section-title">👆 父母</div>';
  }
  if (parents.father) {
    var f = parents.father;
    var fRel = '';
    if (selfId && selfId !== f.id) { var kt = getKinshipTerm(selfId, f.id); if (kt) fRel = '<span class="family-card-relation">我的' + kt + '</span>'; }
    else if (selfId && selfId === f.id) fRel = '<span class="family-card-relation">⭐ 我</span>';
    html += '<div class="family-card parent-card" onclick="renderFamilyView(' + f.id + ')">' +
      '<div class="family-card-av">' + (f.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + f.photo + '" alt="' + f.name + '">' : f.name[0]) + '</div>' +
      '<div class="family-card-info"><div class="family-card-name">' + f.name + ' ' + fRel + '</div>' +
      '<div class="family-card-detail">' + formatGen(f.gen) + ' · ' + f.gender + '</div></div>' +
      '<span class="family-card-arrow">›</span></div>';
  }
  if (parents.mother) {
    var m = parents.mother;
    var mRel = '';
    if (selfId && selfId !== m.id) { var kt2 = getKinshipTerm(selfId, m.id); if (kt2) mRel = '<span class="family-card-relation">我的' + kt2 + '</span>'; }
    else if (selfId && selfId === m.id) mRel = '<span class="family-card-relation">⭐ 我</span>';
    html += '<div class="family-card parent-card" onclick="renderFamilyView(' + m.id + ')">' +
      '<div class="family-card-av">' + (m.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + m.photo + '" alt="' + m.name + '">' : m.name[0]) + '</div>' +
      '<div class="family-card-info"><div class="family-card-name">' + m.name + ' ' + mRel + '</div>' +
      '<div class="family-card-detail">' + formatGen(m.gen) + ' · ' + m.gender + '</div></div>' +
      '<span class="family-card-arrow">›</span></div>';
  }

  // In-law parents: when viewing a spouse without own parents, show partner's parents
  if (!parents.father && !parents.mother && person.spouseOfId) {
    var inlawParents = getParents(person.spouseOfId);
    var inlawLabel = person.gender === '女' ? '👆 公婆' : '👆 岳父母';
    if (inlawParents.father || inlawParents.mother) {
      html += '<div class="family-section-title">' + inlawLabel + '</div>';
    }
    if (inlawParents.father) {
      var ilf = inlawParents.father;
      html += '<div class="family-card parent-card inlaw-card" onclick="renderFamilyView(' + ilf.id + ')">' +
        '<div class="family-card-av">' + (ilf.photo ? '<img loading="lazy" decoding="async" src="' + ilf.photo + '" alt="' + ilf.name + '">' : ilf.name[0]) + '</div>' +
        '<div class="family-card-info"><div class="family-card-name">' + ilf.name + '</div>' +
        '<div class="family-card-detail">' + formatGen(ilf.gen) + ' · ' + ilf.gender + '</div></div>' +
        '<span class="family-card-arrow">›</span></div>';
    }
    if (inlawParents.mother) {
      var ilm = inlawParents.mother;
      html += '<div class="family-card parent-card inlaw-card" onclick="renderFamilyView(' + ilm.id + ')">' +
        '<div class="family-card-av">' + (ilm.photo ? '<img loading="lazy" decoding="async" src="' + ilm.photo + '" alt="' + ilm.name + '">' : ilm.name[0]) + '</div>' +
        '<div class="family-card-info"><div class="family-card-name">' + ilm.name + '</div>' +
        '<div class="family-card-detail">' + formatGen(ilm.gen) + ' · ' + ilm.gender + '</div></div>' +
        '<span class="family-card-arrow">›</span></div>';
    }
  }

  // Siblings section — other children of father
  var siblings = [];
  var fatherId = person.parentId;
  if (fatherId) {
    var allFatherChildren = getChildren(fatherId);
    siblings = allFatherChildren.filter(function(c){ return c.id !== person.id; });
  }
  if (siblings.length > 0) {
    html += '<div class="family-section-title">👫 兄弟姐妹（' + siblings.length + '人）</div>';
    html += '<div class="family-children-grid">';
    siblings.forEach(function(sib){
      var sibRel = '';
      if (selfId && selfId === sib.id) sibRel = '<span class="family-card-relation">⭐ 我</span>';
      else if (selfId) { var kt5 = getKinshipTerm(selfId, sib.id); if (kt5) sibRel = '<span class="family-card-relation">我的' + kt5 + '</span>'; }
      html += '<div class="family-card sibling-card" onclick="renderFamilyView(' + sib.id + ')">' +
        '<div class="family-card-av">' + (sib.photo ? '<img loading="lazy" decoding="async" src="' + sib.photo + '" alt="' + sib.name + '">' : sib.name[0]) + '</div>' +
        '<div class="family-card-info"><div class="family-card-name">' + sib.name + ' ' + sibRel + '</div>' +
        '<div class="family-card-detail">' + formatGen(sib.gen) + ' · ' + sib.gender + '</div></div>' +
        '<span class="family-card-arrow">›</span></div>';
    });
    html += '</div>';
  }

  // Self card
  var selfRelLabel = '';
  if (selfId && selfId === person.id) selfRelLabel = '<span class="family-card-relation">⭐ 我</span>';
  var selfBtnHtml = '';
  if (selfId && selfId === person.id) {
    selfBtnHtml = '<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();clearSelf()" style="font-size:.7rem;padding:3px 10px;color:#c0392b">取消自己</button>';
  } else {
    selfBtnHtml = '<button class="btn btn-primary btn-sm" onclick="event.stopPropagation();setSelf(' + person.id + ')" style="font-size:.7rem;padding:3px 10px">👤 设为我自己</button>';
  }
  html += '<div class="family-section-title">👤 本人</div>';
  html += '<div class="family-card self" onclick="openMemberDetail(' + person.id + ')">' +
    '<div class="family-card-av">' + (person.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + person.photo + '" alt="' + person.name + '">' : person.name[0]) + '</div>' +
    '<div class="family-card-info"><div class="family-card-name">' + person.name + ' ' + selfRelLabel + '</div>' +
    '<div class="family-card-detail">' + formatGen(person.gen) + ' · ' + person.gender + '</div></div>' +
    selfBtnHtml +
    '</div>';

	  // Spouse section — use getMyAllSpouses to handle both directions
	  var allSpouses = getMyAllSpouses(person.id);
	  if (allSpouses.length > 0) {
	    html += '<div class="family-section-title">💑 配偶</div>';
	    allSpouses.forEach(function(s){
	      var sRel = '';
	      if (selfId && selfId === s.id) sRel = '<span class="family-card-relation">⭐ 我</span>';
	      else if (selfId) { var kt3 = getKinshipTerm(selfId, s.id); if (kt3) sRel = '<span class="family-card-relation">我的' + kt3 + '</span>'; }
	      html += '<div class="family-card spouse" onclick="renderFamilyView(' + s.id + ')">' +
	        '<div class="family-card-av">' + (s.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + s.photo + '" alt="' + s.name + '">' : s.name[0]) + '</div>' +
	        '<div class="family-card-info"><div class="family-card-name">' + s.name + ' ' + sRel + '</div>' +
	        '<div class="family-card-detail">' + formatGen(s.gen) + ' · ' + s.gender + '</div></div>' +
	        '<span class="family-card-arrow">›</span></div>';
	    });
	  }

	  // Children section — also check partner's children when person is a spouse
	  var children = getChildren(person.id);
	  if (children.length === 0 && person.spouseOfId) {
	    children = getChildren(person.spouseOfId);
	  }
	  if (children.length > 0) {
	    html += '<div class="family-section-title">👇 子女（' + children.length + '人）</div>';
	    html += '<div class="family-children-grid">';
	    children.forEach(function(c){
	      var cRel = '';
	      if (selfId && selfId === c.id) cRel = '<span class="family-card-relation">⭐ 我</span>';
	      else if (selfId) { var kt4 = getKinshipTerm(selfId, c.id); if (kt4) cRel = '<span class="family-card-relation">我的' + kt4 + '</span>'; }
	      html += '<div class="family-card child-card" onclick="renderFamilyView(' + c.id + ')">' +
	        '<div class="family-card-av">' + (c.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + c.photo + '" alt="' + c.name + '">' : c.name[0]) + '</div>' +
	        '<div class="family-card-info"><div class="family-card-name">' + c.name + ' ' + cRel + '</div>' +
	        '<div class="family-card-detail">' + formatGen(c.gen) + ' · ' + c.gender + '</div></div>' +
	        '<span class="family-card-arrow">›</span></div>';
	    });
	    html += '</div>';
	  } else {
	    html += '<div class="family-section-title">👇 子女</div>';
	    html += '<div class="family-empty">暂无子女记录</div>';
	  }

  container.innerHTML = html;
  container.scrollIntoView({behavior: "smooth", block: "start"});
}

function renderTree() {
  const container = document.getElementById('tree-container');
  container.innerHTML = '';
  container.style.cssText = 'display:inline-flex;flex-direction:row;align-items:flex-start;gap:30px;padding:20px;min-width:max-content;';

  const roots = getRoots();
  if(roots.length === 0) {
    container.innerHTML = '<div style="padding:40px;color:var(--text-light);font-size:.9rem">暂无族人数据。请在管理模式下点击「添加始祖」开始建立族谱。</div>';
    return;
  }

  roots.forEach(root => {
    const branch = renderBranch(root);
    container.appendChild(branch);
  });
  // Init pan/zoom only once (guard with flag)
  if(!window._treeInteractionInited) {
    initTreeInteraction();
    window._treeInteractionInited = true;
  }
  // Auto-fit after layout
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      autoFitTree();
    });
  });
}

// ===== MEMBERS =====
let currentFilter = 'all';
function renderMembers() {
  renderGenFilter();
  renderMemberCards();
}
function renderGenFilter() {
  const bar = document.getElementById('gen-filter');
  const gens = [...new Set(members.map(m=>m.gen))].sort((a,b)=>a-b);
  bar.innerHTML='<button class="filter-btn'+(currentFilter==='all'?' active':'')+'" onclick="filterGen(\'all\')">全部</button>';
  gens.forEach(g=>{
    bar.innerHTML+=`<button class="filter-btn${currentFilter==g?' active':''}" onclick="filterGen(${g})">${formatGen(g,'short')}</button>`;
  });
}
function filterGen(g) {
  currentFilter=g;
  renderGenFilter();
  renderMemberCards();
}
function sortMembers(list) {
  // Separate main members and spouses
  var main = [], spouseMap = {};
  list.forEach(function(m) {
    if (m.spouseOfId) {
      if (!spouseMap[m.spouseOfId]) spouseMap[m.spouseOfId] = [];
      spouseMap[m.spouseOfId].push(m);
    } else {
      main.push(m);
    }
  });
  // Sort main members: gen asc, then birth asc (older first)
  main.sort(function(a, b) {
    if (a.gen !== b.gen) return a.gen - b.gen;
    var ay = getBirthYear(a), by = getBirthYear(b);
    if (ay === null && by === null) return 0;
    if (ay === null) return 1;
    if (by === null) return -1;
    if (ay !== by) return ay - by;
    var da = parseBirthDate(a.birth), db = parseBirthDate(b.birth);
    var am = da.month ? parseInt(da.month) : 0;
    var bm = db.month ? parseInt(db.month) : 0;
    if (am !== bm) return am - bm;
    var ad = da.day ? parseInt(da.day) : 0;
    var bd = db.day ? parseInt(db.day) : 0;
    return ad - bd;
  });
  // Interleave: each main member followed by their spouse(s)
  var result = [];
  var placedSpouseIds = {};
  main.forEach(function(m) {
    result.push(m);
    var spouses = spouseMap[m.id];
    if (spouses) {
      spouses.forEach(function(s) { result.push(s); placedSpouseIds[s.id] = true; });
    }
  });
  // Append any orphan spouses (main member not in list)
  list.forEach(function(m) {
    if (m.spouseOfId && !placedSpouseIds[m.id]) result.push(m);
  });
  return result;
}

function renderMemberCards() {
  var grid = document.getElementById('members-grid');
  var list;
  if (currentFilter === 'all') {
    list = members.slice();
  } else {
    // Include members of this gen AND their spouses
    var genMembers = members.filter(function(m) { return m.gen === currentFilter && !m.spouseOfId; });
    list = genMembers.slice();
    genMembers.forEach(function(m) {
      var spouses = getSpouses(m.id);
      spouses.forEach(function(s) { if (list.indexOf(s) === -1) list.push(s); });
    });
  }
  list = sortMembers(list);
  if (list.length === 0) { grid.innerHTML='<div style="color:var(--text-light);font-size:.9rem;padding:20px">暂无族人，点击「添加族人」开始录入。</div>'; return; }
  var selfId = config.selfId || null;
  grid.innerHTML = list.map(function(m){
    var kinship = '';
    if (selfId && m.id !== selfId) {
      var term = getKinshipTerm(selfId, m.id);
      if (term) kinship = '<div class="member-kinship">我的' + term + '</div>';
    }
    return '<div class="member-card" onclick="openMemberDetail(' + m.id + ')">' +
      '<button class="card-del-btn" onclick="event.stopPropagation();deleteMember(' + m.id + ')">删除</button>' +
      '<button class="card-edit-btn" onclick="event.stopPropagation();openMemberForm(' + m.id + ',null,\'edit\')">编辑</button>' +
      '<div class="member-av">' + (m.photo ? '<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="' + m.photo + '" alt="' + m.name + '">' : m.name[0]) + '</div>' +
      '<div class="member-name">' + m.name + '</div>' +
      '<div class="member-gen">' + formatGen(m.gen) + (m.spouseOfId ? '（配偶）' : '') + '</div>' +
      kinship +
      '<div class="member-info">' + m.gender + ' · ' + formatBirth(m.birth) + '</div>' +
      '<div class="member-info">' + (m.job||'') + '</div>' +
      '</div>';
  }).join('');
}

function openMemberDetail(id) {
  const m = members.find(x=>x.id===id); if(!m) return;
  const av = document.getElementById('m-av');
  if(m.photo) { av.innerHTML=`<img loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" loading="lazy" decoding="async" src="${m.photo}" alt="${m.name}" style="width:100%;height:100%;object-fit:cover;border-radius:12px">`; }
  else { av.textContent=m.name[0]; }
  document.getElementById('m-name').textContent=m.name;
  let genLabel = formatGen(m.gen);
  if(m.spouseOfId) {
    const sp = members.find(x=>x.id===m.spouseOfId);
    genLabel += sp ? '（'+sp.name+'之配偶）' : '（配偶）';
  } else {
    var sps = members.filter(function(x){return x.spouseOfId===m.id;});
    if (sps.length > 0) {
      genLabel += '（配偶：'+sps.map(function(x){return x.name;}).join('、')+'）';
    }
  }
  document.getElementById('m-gen').textContent=genLabel;
  document.getElementById('m-gender').textContent=m.gender||'—';
  document.getElementById('m-birth').textContent=formatBirth(m.birth);
  // Death date and age
  var deathRow = document.getElementById('m-death-row');
  var ageRow = document.getElementById('m-age-row');
  if (m.death) {
    document.getElementById('m-death').textContent = formatDeath(m.death);
    deathRow.style.display = 'flex';
    var ageText = calcAge(m.birth, m.death);
    if (ageText) {
      document.getElementById('m-age').textContent = ageText;
      ageRow.style.display = 'flex';
    } else {
      ageRow.style.display = 'none';
    }
  } else {
    deathRow.style.display = 'none';
    ageRow.style.display = 'none';
  }
  document.getElementById('m-origin').textContent=m.origin||'—';
  document.getElementById('m-job').textContent=m.job||'—';
  document.getElementById('m-bio').textContent=m.bio||'—';

  // Kinship term
  var selfId = config.selfId || null;
  var kinRow = document.getElementById('m-kinship-row');
  var kinDiv = document.getElementById('m-kinship-divider');
  if (selfId && m.id !== selfId) {
    var term = getKinshipTerm(selfId, m.id);
    if (term) {
      document.getElementById('m-kinship').textContent = '我的' + term;
      kinRow.style.display = 'flex';
      kinDiv.style.display = 'block';
    } else {
      kinRow.style.display = 'none';
      kinDiv.style.display = 'none';
    }
  } else if (selfId && m.id === selfId) {
    document.getElementById('m-kinship').textContent = '这就是我';
    kinRow.style.display = 'flex';
    kinDiv.style.display = 'block';
  } else {
    kinRow.style.display = 'none';
    kinDiv.style.display = 'none';
  }

  const rel = document.getElementById('m-relations');
  const relItems = [];
  // Parent
  if(m.parentId) {
    const parent = members.find(x=>x.id===m.parentId);
    if(parent) relItems.push({label:'父/母：'+parent.name, id:parent.id});
  }
  // Spouses
  if(m.spouseOfId) {
    const sp = members.find(x=>x.id===m.spouseOfId);
    if(sp) relItems.push({label:'配偶：'+sp.name, id:sp.id});
  }
  const mySpouses = members.filter(x=>x.spouseOfId===m.id);
  mySpouses.forEach(function(sp, i){
    relItems.push({label:(mySpouses.length>1?'配偶'+(i+1)+'：':'配偶：')+sp.name, id:sp.id});
  });
  // Children
  const children = getChildren(m.id);
  children.forEach(c=>relItems.push({label:'子女：'+c.name, id:c.id}));
  // Siblings
  if(m.parentId) {
    const siblings = members.filter(x=>x.parentId===m.parentId&&x.id!==m.id&&!x.spouseOfId);
    siblings.forEach(s=>relItems.push({label:'兄弟姐妹：'+s.name, id:s.id}));
  }

  rel.innerHTML = relItems.length
    ? relItems.map(r=>`<span class="rel-tag" onclick="openMemberDetail(${r.id})">${r.label}</span>`).join('')
    : '<span style="font-size:.8rem;color:var(--text-light)">暂无关联亲属</span>';
  // Store current member id for album
  document.getElementById('album-modal').dataset.memberId = m.id;
  openModal('member-modal');
}

// openMemberForm(id, parentId, type)
// type: 'edit' | 'child' | 'spouse'
function openMemberForm(id, parentId, type) {
  type = type || 'child';
  document.getElementById('mf-id').value = id||'';
  document.getElementById('mf-parent-id').value = parentId||'';
  document.getElementById('mf-add-type').value = type;
  setPhotoPreview(null);

  if(type === 'edit' && id) {
    document.getElementById('member-form-title').textContent = '编辑族人';
    const m = members.find(x=>x.id===id); if(!m) return;
    document.getElementById('mf-name').value=m.name;
    document.getElementById('mf-gender').value=m.gender||'男';
    setBirthFields(m.birth);
    setDeathFields(m.death||'');
    document.getElementById('mf-origin').value=m.origin||'';
    document.getElementById('mf-job').value=m.job||'';
    document.getElementById('mf-bio').value=m.bio||'';
    if(m.photo) setPhotoPreview(m.photo);
    document.getElementById('mf-parent-group').style.display='none';
  } else if(type === 'spouse') {
    document.getElementById('member-form-title').textContent = '添加配偶';
    document.getElementById('mf-name').value='';
    document.getElementById('mf-gender').value='女';
    setBirthFields('');
    setDeathFields('');
    document.getElementById('mf-origin').value='';
    document.getElementById('mf-job').value='';
    document.getElementById('mf-bio').value='';
    document.getElementById('mf-parent-group').style.display='none';
  } else {
    // child or new root
    document.getElementById('member-form-title').textContent = parentId ? '添加子女' : '添加始祖';
    document.getElementById('mf-name').value='';
    document.getElementById('mf-gender').value='男';
    setBirthFields('');
    setDeathFields('');
    document.getElementById('mf-origin').value='';
    document.getElementById('mf-job').value='';
    document.getElementById('mf-bio').value='';
    // Show parent selector only when adding a child without a fixed parent
    if(!parentId) {
      const sel = document.getElementById('mf-parent-select');
      sel.innerHTML = '<option value="">无（作为始祖）</option>';
      members.filter(m=>!m.spouseOfId).forEach(m=>{
        sel.innerHTML += `<option value="${m.id}">${formatGen(m.gen,'short')} ${m.name}</option>`;
      });
      document.getElementById('mf-parent-group').style.display='block';
    } else {
      document.getElementById('mf-parent-group').style.display='none';
    }
  }
  openModal('member-form-modal');
}

function saveMember() {
  const name = document.getElementById('mf-name').value.trim();
  if(!name) { showToast('请输入姓名','error'); return; }
  const id = parseInt(document.getElementById('mf-id').value)||0;
  const type = document.getElementById('mf-add-type').value;
  let parentId = parseInt(document.getElementById('mf-parent-id').value)||null;
  const photoPreview = document.getElementById('mf-photo-preview');
  const photo = (photoPreview.style.display!=='none' && photoPreview.src && photoPreview.src !== window.location.href) ? photoPreview.src : null;

  if(type === 'child' && !parentId) {
    const selVal = parseInt(document.getElementById('mf-parent-select').value)||null;
    parentId = selVal;
  }

  // Resolve parent birth year for age validation
  var parentYear = null;
  if (type === 'edit' && id) {
    var editM = members.find(function(x){return x.id===id;});
    if (editM && editM.parentId) {
      var ep = members.find(function(x){return x.id===editM.parentId;});
      if (ep && ep.birth) { var epd = parseBirthDate(ep.birth); parentYear = epd.year ? parseInt(epd.year) : null; }
    }
  } else if (type === 'child' && parentId) {
    var cp = members.find(function(x){return x.id===parentId;});
    if (cp && cp.birth) { var cpd = parseBirthDate(cp.birth); parentYear = cpd.year ? parseInt(cpd.year) : null; }
  }
  const birthErr = validateBirth(parentYear);
  if(birthErr) { showToast(birthErr,'error'); return; }

  if(type === 'edit' && id) {
    const i = members.findIndex(x=>x.id===id);
    if(i>=0) {
      members[i] = {...members[i],
        name,
        gender: document.getElementById('mf-gender').value,
        birth: getBirthValue(),
        origin: document.getElementById('mf-origin').value,
        job: document.getElementById('mf-job').value,
        bio: document.getElementById('mf-bio').value,
        death: getDeathValue(),
        photo
      };
    }
    showToast('已更新族人信息','success');
  } else if(type === 'spouse') {
    const spouseOfId = parseInt(document.getElementById('mf-parent-id').value)||null;
    const spouseOf = spouseOfId ? members.find(x=>x.id===spouseOfId) : null;
    const gen = spouseOf ? spouseOf.gen : 1;
    const data = {
      id: nextMemberId++, name,
      gen,
      gender: document.getElementById('mf-gender').value,
      birth: getBirthValue(),
      origin: document.getElementById('mf-origin').value,
      job: document.getElementById('mf-job').value,
      bio: document.getElementById('mf-bio').value,
      death: getDeathValue(),
      photo,
      parentId: null,
      spouseOfId
    };
    members.push(data);
    showToast('已添加配偶','success');
  } else {
    // child or root
    const parent = parentId ? members.find(x=>x.id===parentId) : null;
    const gen = parent ? parent.gen + 1 : 1;
    if(gen > 20) { showToast('已达最大世代（20世）','error'); return; }
    const data = {
      id: nextMemberId++, name,
      gen,
      gender: document.getElementById('mf-gender').value,
      birth: getBirthValue(),
      origin: document.getElementById('mf-origin').value,
      job: document.getElementById('mf-job').value,
      bio: document.getElementById('mf-bio').value,
      death: getDeathValue(),
      photo,
      parentId: parentId || null,
      spouseOfId: null
    };
    members.push(data);
    showToast('已添加族人','success');
  }

  saveData('ft_members', members);
  closeModal('member-form-modal');
  renderMembers();
  updateHomeStats();
  refreshView();
}

async function deleteMember(id) {
  const m = members.find(x=>x.id===id); if(!m) return;
  // Check for descendants
  const hasChildren = members.some(x=>x.parentId===id);
  const hasSpouse = members.some(x=>x.spouseOfId===id);
  let msg = `确定要删除「${m.name}」吗？此操作不可撤销。`;
  if(hasChildren) msg += '\n\n⚠️ 该成员有子女，删除后子女将失去父节点（变为独立根节点）。';
  if(hasSpouse) msg += '\n\n⚠️ 该成员有配偶，配偶记录也将一并删除。';
  const ok = await showConfirm('删除族人', msg);
  if(!ok) return;
  // Remove spouse
  if(hasSpouse) members = members.filter(x=>x.spouseOfId!==id);
  // Detach children (set parentId to null)
  members.forEach(x=>{ if(x.parentId===id) x.parentId=null; });
  members = members.filter(x=>x.id!==id);
  if(config.selfId === id) { config.selfId = null; saveData('ft_config', config); updateSelfDisplay(); }
  saveData('ft_members',members);
  renderMembers();
  updateHomeStats();
  refreshView();
  showToast('已删除');
}

// ===== PHOTO =====
function setPhotoPreview(src) {
  const preview = document.getElementById('mf-photo-preview');
  const placeholder = document.getElementById('mf-photo-placeholder');
  const removeBtn = document.getElementById('mf-photo-remove');
  if(src) {
    preview.src = src;
    preview.style.display = 'block';
    placeholder.style.display = 'none';
    removeBtn.style.display = 'block';
  } else {
    preview.src = '';
    preview.style.display = 'none';
    placeholder.style.display = 'block';
    removeBtn.style.display = 'none';
    document.getElementById('mf-photo-input').value = '';
  }
}
function compressBgImage(file, callback) {
  var reader = new FileReader();
  reader.onload = function(e) {
    var img = new Image();
    img.onload = function() {
      var maxW = 800, maxH = 800;
      var w = img.width, h = img.height;
      if (w <= maxW && h <= maxH) { callback(e.target.result); return; }
      var ratio = Math.min(maxW / w, maxH / h);
      var cw = Math.round(w * ratio), ch = Math.round(h * ratio);
      var canvas = document.createElement('canvas');
      canvas.width = cw; canvas.height = ch;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, cw, ch);
      callback(canvas.toDataURL('image/jpeg', 0.7));
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}
function compressImage(file, callback) {
  var reader = new FileReader();
  reader.onload = function(e) {
    var img = new Image();
    img.onload = function() {
      var maxW = 400, maxH = 400;
      var w = img.width, h = img.height;
      if (w <= maxW && h <= maxH) { callback(e.target.result); return; }
      var ratio = Math.min(maxW / w, maxH / h);
      var cw = Math.round(w * ratio), ch = Math.round(h * ratio);
      var canvas = document.createElement('canvas');
      canvas.width = cw; canvas.height = ch;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, cw, ch);
      callback(canvas.toDataURL('image/jpeg', 0.5));
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}
function handlePhotoUpload(e) {
  const file = e.target.files[0];
  if(!file) return;
  if(file.size > 2*1024*1024) { showToast('图片不能超过 2MB','error'); return; }
  compressImage(file, function(compressed) { setPhotoPreview(compressed); });
}
function removePhoto() { setPhotoPreview(null); }

// Story photo
function setStoryPhotoPreview(src) {
  const preview = document.getElementById('sf-photo-preview');
  const placeholder = document.getElementById('sf-photo-placeholder');
  const removeBtn = document.getElementById('sf-photo-remove');
  if(src) {
    preview.src = src;
    preview.style.display = 'block';
    placeholder.style.display = 'none';
    removeBtn.style.display = 'block';
  } else {
    preview.src = '';
    preview.style.display = 'none';
    placeholder.style.display = 'block';
    removeBtn.style.display = 'none';
    document.getElementById('sf-photo-input').value = '';
  }
}
function handleStoryPhotoUpload(e) {
  const file = e.target.files[0];
  if(!file) return;
  if(file.size > 2*1024*1024) { showToast('图片不能超过 2MB','error'); return; }
