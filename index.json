// ===== TREE SEARCH =====
let _searchIdx = 0;
function handleTreeSearch(query) {
  const resultsEl = document.getElementById('tree-search-results');
  const clearBtn = document.getElementById('tree-search-clear');
  const q = query.trim().toLowerCase();
  clearHighlight();
  if(!q) {
    resultsEl.innerHTML=''; resultsEl.classList.remove('open');
    clearBtn.classList.remove('visible'); return;
  }
  clearBtn.classList.add('visible');
  _searchIdx = 0;
  const matches = members.filter(m => m.name.toLowerCase().includes(q));
  if(matches.length === 0) {
    resultsEl.innerHTML='<div class="tree-search-empty">未找到匹配的族人</div>';
    resultsEl.classList.add('open'); return;
  }
  matches.forEach(m => {
    const el = document.querySelector(`.t-node[data-member-id="${m.id}"]`);
    if(el) el.classList.add('highlight');
  });
  resultsEl.innerHTML = matches.map((m, i) =>
    `<div class="tree-search-item${i===0?' active':''}" data-index="${i}" data-member-id="${m.id}" onmousedown="event.preventDefault();locateMember(${m.id})">
      <div class="tree-search-item-av">${m.name[0]}</div>
      <div class="tree-search-item-name">${m.name}</div>
      <div class="tree-search-item-gen">${formatGen(m.gen,'short')}</div>
    </div>`
  ).join('');
  resultsEl.classList.add('open');
}

function locateMember(id) {
  document.getElementById('tree-search-results').classList.remove('open');
  document.getElementById('tree-search-clear').classList.remove('visible');
  clearHighlight();
  const target = document.querySelector(`.t-node[data-member-id="${id}"]`);
  if(!target) return;
  target.classList.add('highlight');
  panToNode(target);
}

function panToNode(el) {
  var wrap = document.getElementById('tree-wrap');
  var scaleWrap = document.getElementById('tree-scale-wrap');
  var wrapW = wrap.clientWidth;
  var wrapH = wrap.clientHeight;

  // Save and reset transform to measure natural layout
  var prevTrans = scaleWrap.style.transition;
  scaleWrap.style.transition = 'none';
  scaleWrap.style.transform = '';

  // Measure node in natural (unscaled) layout
  var nRect = el.getBoundingClientRect();
  var swRect = scaleWrap.getBoundingClientRect();
  var nCX = nRect.left + nRect.width / 2 - swRect.left;
  var nCY = nRect.top + nRect.height / 2 - swRect.top;
  var nW = nRect.width;

  // Pick zoom: make node ~150px on screen, capped
  var targetScale = Math.min(1.5, 150 / Math.max(nW, 1));
  targetScale = Math.max(0.15, targetScale);

  // Translation to center node at target scale
  treeTx = wrapW / 2 - nCX * targetScale;
  treeTy = wrapH / 2 - nCY * targetScale;
  treeScale = targetScale;

  // Restore transition and apply
  scaleWrap.style.transition = prevTrans;
  applyTreeTransform(true);
}

function clearHighlight() {
  document.querySelectorAll('.t-node.highlight').forEach(el => el.classList.remove('highlight'));
}

function clearTreeSearch() {
  const input = document.getElementById('tree-search-input');
  input.value = '';
  document.getElementById('tree-search-results').classList.remove('open');
  document.getElementById('tree-search-results').innerHTML = '';
  document.getElementById('tree-search-clear').classList.remove('visible');
  clearHighlight();
  input.focus();
}

// Close search dropdown on outside click
document.addEventListener('click', e => {
  const wrap = document.querySelector('.tree-search-wrap');
  if(wrap && !wrap.contains(e.target)) {
    document.getElementById('tree-search-results').classList.remove('open');
  }
});

// Keyboard nav for search results
document.addEventListener('keydown', e => {
  const resultsEl = document.getElementById('tree-search-results');
  if(!resultsEl.classList.contains('open')) return;
  const items = resultsEl.querySelectorAll('.tree-search-item');
  if(items.length === 0) return;
  let idx = -1;
  items.forEach((it,i)=>{if(it.classList.contains('active')) idx=i;});
  if(e.key==='ArrowDown'){
    e.preventDefault();
    items[idx].classList.remove('active');
    const next = (idx+1)%items.length;
    items[next].classList.add('active');
    items[next].scrollIntoView({block:'nearest'});
  } else if(e.key==='ArrowUp'){
    e.preventDefault();
    items[idx].classList.remove('active');
    const prev = (idx-1+items.length)%items.length;
    items[prev].classList.add('active');
    items[prev].scrollIntoView({block:'nearest'});
  } else if(e.key==='Enter'){
    e.preventDefault();
    const active = resultsEl.querySelector('.tree-search-item.active');
    if(active) locateMember(parseInt(active.dataset.memberId));
  } else if(e.key==='Escape'){
    clearTreeSearch();
  }
});

