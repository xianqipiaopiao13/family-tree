<body data-theme="imperial" class="">
<div id="lock-overlay">
  <div class="lock-card">
    <div class="lock-icon">🏠</div>
    <div class="lock-title">朱氏三厢房家族族谱</div>
    <div class="lock-subtitle">请输入密码查看</div>
    <div class="lock-input-wrap" id="lock-dots" style="position:relative">
      <div class="lock-dot" data-i="0"></div>
      <div class="lock-dot" data-i="1"></div>
      <div class="lock-dot" data-i="2"></div>
      <div class="lock-dot" data-i="3"></div>
      <input type="number" class="hidden-input" id="lock-input" inputmode="numeric" maxlength="4">
    </div>
    <div class="lock-error" id="lock-error">密码不正确</div>
    <div class="lock-hint">点击上方圆点输入数字密码</div>
  </div>
</div>
<script>
(function(){
  var PASS = '4646';
  var STORAGE_KEY = 'ft_unlocked';

  function isUnlocked() {
    var params = new URLSearchParams(location.search);
    if (params.get('key') === PASS) {
      sessionStorage.setItem(STORAGE_KEY, '1');
      params.delete('key');
      var newUrl = location.pathname + (params.toString() ? '?' + params.toString() : '');
      history.replaceState(null, '', newUrl);
      return true;
    }
    return sessionStorage.getItem(STORAGE_KEY) === '1';
  }

  if (isUnlocked()) {
    document.getElementById('lock-overlay').classList.add('hidden');
    return;
  }

  var input = document.getElementById('lock-input');
  var dots = document.querySelectorAll('.lock-dot');
  var errorEl = document.getElementById('lock-error');
  var code = '';

  function updateDots() {
    dots.forEach(function(d, i) {
      if (i < code.length) d.classList.add('filled');
      else d.classList.remove('filled');
    });
  }

  function clearError() { errorEl.style.display = 'none'; }

  function shake() {
    dots.forEach(function(d) { d.classList.add('error'); });
    errorEl.style.display = 'block';
    setTimeout(function() {
      dots.forEach(function(d) { d.classList.remove('error'); });
      code = '';
      updateDots();
    }, 500);
  }

  document.getElementById('lock-dots').addEventListener('click', function() {
    input.focus();
  });

  input.addEventListener('input', function() {
    clearError();
    var val = input.value.replace(/\D/g, '');
    if (val.length > 4) val = val.slice(0, 4);
    code = val;
    input.value = code;
    updateDots();
    if (code.length === 4) {
      if (code === PASS) {
        sessionStorage.setItem(STORAGE_KEY, '1');
        document.getElementById('lock-overlay').classList.add('hidden');
      } else {
        shake();
        input.value = '';
      }
    }
  });

  setTimeout(function() { input.focus(); }, 500);
})();
</script>

<!-- SPLASH 引导页 -->
<div class="splash fade-out" id="splash" style="display: none;">
  <div id="splash-slides">
    <div class="splash-slide active" data-index="0">
      <div class="splash-slide-bg" style="background:url('images/img_001.jpg') center/cover"></div>
      <div class="splash-slide-content">
        <div class="splash-slide-title">朱氏三厢房族谱</div>
        <div class="splash-slide-sub">无论走到哪里，走了多远<br>家族永远是我们最温暖的港湾</div>
      </div>
      <div class="splash-slide-index">1 / 1</div>
      <div class="splash-admin-controls">
        <button class="splash-admin-btn" onclick="event.stopPropagation();openSplashSlideForm(0)" title="编辑">✎</button>
        <button class="splash-admin-btn del" onclick="event.stopPropagation();deleteSplashSlide(0)" title="删除">✕</button>
      </div>
    </div></div>
  <div class="splash-dots" id="splash-dots"><span class="splash-dot active" data-index="0" onclick="event.stopPropagation();goToSplashSlide(0)"></span></div>
  <button class="splash-add-slide" id="splash-add-btn" onclick="addSplashSlide()">＋ 添加幻灯片</button>
  <button class="splash-skip" onclick="skipSplash()">跳过 ›</button>
  <div class="splash-hint">单击切换 · 双击跳过</div>
</div>

<script>
(function(){var s=document.getElementById("splash");if(!s)return;var t=null, f=false;
function h(e){if(e.target.closest(".splash-skip")||e.target.closest(".splash-dot"))return;
if(t){clearTimeout(t);t=null;s.classList.add("fade-out");setTimeout(function(){s.style.display="none"},500);localStorage.setItem("ft_splash_seen","1");var r=document.getElementById("splash-replay-btn");if(r)r.classList.add("visible")}
else{t=setTimeout(function(){t=null;var sl=s.querySelectorAll(".splash-slide");var cur=s.querySelector(".splash-slide.active");var idx=cur?parseInt(cur.getAttribute("data-index")):-1;
if(idx>=0&&idx<sl.length-1){cur.classList.remove("active");sl[idx+1].classList.add("active");var dots=document.querySelectorAll("#splash-dots .splash-dot");dots.forEach(function(d,i){d.classList.toggle("active",i===idx+1)});var idxEl=s.querySelector(".splash-slide-index");if(idxEl)idxEl.textContent=(idx+2)+" / "+sl.length}
else{s.classList.add("fade-out");setTimeout(function(){s.style.display="none"},500);localStorage.setItem("ft_splash_seen","1");var r=document.getElementById("splash-replay-btn");if(r)r.classList.add("visible")}},300)}}
s.addEventListener("touchend",function(e){f=true;h(e)});
s.addEventListener("click",function(e){if(f){f=false;return;}h(e)});
})();
</script>

