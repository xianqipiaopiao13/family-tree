<div class="toast success" id="toast">已添加族人</div>

<script>
// ===== SPLASH =====
const DEFAULT_SPLASH = [
  {icon:'🏮', title:'陈氏家族', subtitle:'薪火相传 · 血脉相连 · 家和万事兴',
   gradient:'linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)', image:''},
  {icon:'🚶', title:'先祖南迁', subtitle:'跋山涉水，不远千里\n在南方这片热土开创基业',
   gradient:'linear-gradient(135deg,#3e1f0d 0%,#5d3a1a 50%,#2c1810 100%)', image:''},
  {icon:'🌳', title:'世代传承', subtitle:'几代人栉风沐雨，勤耕不辍\n家业日渐兴旺，枝繁叶茂',
   gradient:'linear-gradient(135deg,#5c0e0e 0%,#8b1a1a 50%,#3e0a0a 100%)', image:''},
  {icon:'🙏', title:'勿忘根本', subtitle:'无论走到哪里，走了多远\n家族永远是我们最温暖的港湾',
   gradient:'linear-gradient(135deg,#4a3000 0%,#7a5500 50%,#3e2500 100%)', image:''}
];

function loadSplashSlides() {
  try {
    const raw = localStorage.getItem('ft_splash_slides');
    if(raw) {
      const parsed = JSON.parse(raw);
      // Migrate from localStorage to IndexedDB
      saveSplashSlidesToIDB(parsed);
      localStorage.removeItem('ft_splash_slides');
      return parsed;
    }
  } catch(e) {}
  return [...DEFAULT_SPLASH];
}

// IndexedDB for splash slides (supports large images)
function openSplashDB() {
  return new Promise((resolve, reject) => {
    const request = indexedDB.open('FamilySplashDB', 1);
    request.onupgradeneeded = () => {
      request.result.createObjectStore('slides', { keyPath: 'idx' });
    };
    request.onsuccess = () => resolve(request.result);
    request.onerror = () => reject(request.error);
  });
}

async function loadSplashSlidesFromIDB() {
  try {
    const db = await openSplashDB();
    const items = await new Promise((resolve) => {
      const tx = db.transaction('slides', 'readonly');
      const req = tx.objectStore('slides').getAll();
      req.onsuccess = () => resolve(req.result);
      req.onerror = () => resolve([]);
    });
    db.close();
    if(items.length > 0) {
      return items.sort((a, b) => a.idx - b.idx).map(i => i.data);
    }
    return loadSplashSlides(); // fallback to localStorage / defaults
  } catch(e) { return loadSplashSlides(); }
}

function saveSplashSlidesToIDB(slides) {
  openSplashDB().then(db => {
    const tx = db.transaction('slides', 'readwrite');
    const store = tx.objectStore('slides');
    store.clear();
    slides.forEach((s, i) => store.put({ idx: i, data: s }));
    tx.oncomplete = () => db.close();
  }).catch(() => {});
}

async function saveSplashSlides() {
  try {
    const db = await openSplashDB();
    const tx = db.transaction('slides', 'readwrite');
    const store = tx.objectStore('slides');
    store.clear();
    splashSlides.forEach((s, i) => store.put({ idx: i, data: s }));
    await new Promise(resolve => { tx.oncomplete = resolve; });
    db.close();
    // Also save backup to localStorage for export
    localStorage.setItem('ft_splash_slides', JSON.stringify(splashSlides));
  } catch(e) { showToast('保存失败，储存空间不足','error'); }
}

let splashSlides = [...DEFAULT_SPLASH];
let splashIndex = 0;
let splashSeen = false;
var IS_STANDALONE = true; // replaced to true during export

function buildSplashSlides() {
  const container = document.getElementById('splash-slides');
  const dots = document.getElementById('splash-dots');
  container.innerHTML = splashSlides.map((s, i) => `
    <div class="splash-slide${i === 0 ? ' active' : ''}" data-index="${i}">
      <div class="splash-slide-bg" style="background:${s.image ? `url('${s.image}') center/cover` : s.gradient}"></div>
      <div class="splash-slide-content">
        <div class="splash-slide-title">${s.title}</div>
        <div class="splash-slide-sub">${s.subtitle.replace(/\n/g,'<br>')}</div>
      </div>
      <div class="splash-slide-index">${i + 1} / ${splashSlides.length}</div>
      <div class="splash-admin-controls">
        <button class="splash-admin-btn" onclick="event.stopPropagation();openSplashSlideForm(${i})" title="编辑">✎</button>
        <button class="splash-admin-btn del" onclick="event.stopPropagation();deleteSplashSlide(${i})" title="删除">✕</button>
      </div>
    </div>`).join('');
  dots.innerHTML = splashSlides.map((_, i) =>
    `<span class="splash-dot${i === 0 ? ' active' : ''}" data-index="${i}" onclick="event.stopPropagation();goToSplashSlide(${i})"></span>`
  ).join('');
}

function goToSplashSlide(idx) {
  if(idx === splashIndex) return;
  const slides = document.querySelectorAll('.splash-slide');
  const dots = document.querySelectorAll('.splash-dot');
  slides.forEach(s => s.classList.remove('active'));
  dots.forEach(d => d.classList.remove('active'));
  splashIndex = idx;
  if(slides[idx]) slides[idx].classList.add('active');
  if(dots[idx]) dots[idx].classList.add('active');
}

function nextSplashSlide() {
  if(splashIndex >= splashSlides.length - 1) { skipSplash(); return; }
  goToSplashSlide(splashIndex + 1);
}

function skipSplash() {
  splashSeen = true;
  localStorage.setItem('ft_splash_seen', '1');
  document.getElementById('splash-replay-btn').classList.add('visible');
  const splash = document.getElementById('splash');
  splash.classList.add('fade-out');
  setTimeout(() => { splash.style.display = 'none'; }, 500);
}

function hasCustomSplash() {
  return DEFAULT_SPLASH.length !== 2
    || DEFAULT_SPLASH[0].title !== '陈氏家族'
    || DEFAULT_SPLASH[1].title !== '先祖南迁';
}

async function replaySplash() {
  splashSeen = false;
  localStorage.removeItem('ft_splash_seen');
  splashIndex = 0;
  if (window.__CUSTOM_SPLASH__) {
    splashSlides = window.__CUSTOM_SPLASH__;
  } else if (hasCustomSplash()) {
    splashSlides = [...DEFAULT_SPLASH];
  } else {
    splashSlides = await loadSplashSlidesFromIDB();
  }
  document.getElementById('splash-replay-btn').classList.remove('visible');
  const splash = document.getElementById('splash');
  splash.style.display = 'flex';
  splash.classList.remove('fade-out');
  buildSplashSlides();
}

// Admin: edit / delete splash slides
function openSplashSlideForm(idx) {
  const s = splashSlides[idx];
  if(!s) return;
  document.getElementById('splash-form-title').textContent = '编辑引导页 · 第' + (idx + 1) + '张';
  document.getElementById('spf-idx').value = idx;
  document.getElementById('spf-title').value = s.title || '';
  document.getElementById('spf-subtitle').value = s.subtitle || '';
  document.getElementById('spf-gradient').value = s.gradient || '';
  setSplashPhotoPreview(s.image || null);
  openModal('splash-form-modal');
}

async function saveSplashSlide() {
  const idx = parseInt(document.getElementById('spf-idx').value);
  const title = document.getElementById('spf-title').value.trim();
  if(!title) { showToast('请输入标题','error'); return; }
  const data = {
    title,
    subtitle: document.getElementById('spf-subtitle').value,
    image: (function(){
      const p = document.getElementById('spf-photo-preview');
      return (p.style.display!=='none' && p.src && p.src !== window.location.href) ? p.src : '';
    })(),
    gradient: document.getElementById('spf-gradient').value || 'linear-gradient(135deg,#1a1a2e,#16213e)'
  };
  if(idx >= 0 && idx < splashSlides.length) {
    splashSlides[idx] = data;
  }
  await saveSplashSlides();
  closeModal('splash-form-modal');
  buildSplashSlides();
  goToSplashSlide(idx);
  showToast('已更新引导页','success');
}

async function deleteSplashSlide(idx) {
  if(splashSlides.length <= 1) { showToast('至少保留一张幻灯片','error'); return; }
  const ok = await showConfirm('删除幻灯片', '确定要删除第' + (idx + 1) + '张引导页吗？');
  if(!ok) return;
  splashSlides.splice(idx, 1);
  await saveSplashSlides();
  if(splashIndex >= splashSlides.length) splashIndex = splashSlides.length - 1;
  buildSplashSlides();
  goToSplashSlide(splashIndex);
  showToast('已删除');
}

async function addSplashSlide() {
  splashSlides.push({
    title:'新幻灯片', subtitle:'点击编辑修改内容',
    gradient:'linear-gradient(135deg,#2c3e50,#3498db)', image:''
  });
  await saveSplashSlides();
  buildSplashSlides();
  goToSplashSlide(splashSlides.length - 1);
  showToast('已添加幻灯片，请点击编辑按钮修改内容','success');
}

// Keyboard: space/right = next, escape = skip
document.addEventListener('keydown', e => {
  const splash = document.getElementById('splash');
  if(splash.style.display === 'none') return;
  if(e.key === 'Escape') skipSplash();
  if(e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); nextSplashSlide(); }
});

// Init
(async function initSplash() {
  // Exported file: custom splash injected via script tag takes highest priority.
  // Fall back to content-based detection, then IndexedDB for the source file.
  if (window.__CUSTOM_SPLASH__) {
    splashSlides = window.__CUSTOM_SPLASH__;
    try { indexedDB.deleteDatabase('FamilySplashDB'); } catch(e) {}
  } else if (hasCustomSplash()) {
    splashSlides = [...DEFAULT_SPLASH];
    try { indexedDB.deleteDatabase('FamilySplashDB'); } catch(e) {}
  } else {
    splashSlides = await loadSplashSlidesFromIDB();
  }
  buildSplashSlides();
  // Always show splash on every open
  var splashEl = document.getElementById('splash');
  splashEl.style.display = 'flex';
  splashEl.classList.remove('fade-out');
  if(localStorage.getItem('ft_splash_seen')) {
    localStorage.removeItem('ft_splash_seen');
  }
})();

// ===== DATA =====
const ADMIN_PW = 'zssxfjzzp.com';
let isAdmin = false;

// Members now have: id, name, gen, gender, birth, origin, job, bio, photo, parentId, spouseOfId
