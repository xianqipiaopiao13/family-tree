  _bdayPeople = [];
}

// ===== CHAT =====
var _mediaRecorder = null;
var _audioChunks = [];
var _recordStartTime = 0;
var _recording = false;

function getSupportedAudioMime() {
  var types = ['audio/webm;codecs=opus', 'audio/webm', 'audio/mp4', 'audio/aac', 'audio/ogg;codecs=opus'];
  for (var i = 0; i < types.length; i++) {
    if (MediaRecorder.isTypeSupported(types[i])) return types[i];
  }
  return 'audio/webm';
}

function startRecording(e) {
  if (_recording) return;
  var user = getCurrentUser();
  if (!user) {
    showToast('请先登录后再发言', 'warning');
    return;
  }
  e.preventDefault();
  _recording = true;
  var micBtn = document.getElementById('chat-mic-btn');
  if (micBtn) {
    micBtn.classList.add('recording');
    micBtn.textContent = '●';
  }
  showToast('🎤 录音中...', 'info');

  navigator.mediaDevices.getUserMedia({audio: true}).then(function(stream) {
    if (!_recording) {
      stream.getTracks().forEach(function(t) { t.stop(); });
      return;
    }
    var mimeType = getSupportedAudioMime();
    _audioChunks = [];
    _recordStartTime = Date.now();
    _mediaRecorder = new MediaRecorder(stream, {mimeType: mimeType});
    _mediaRecorder.ondataavailable = function(ev) {
      if (ev.data && ev.data.size > 0) _audioChunks.push(ev.data);
    };
    _mediaRecorder.onstart = function() {
      // Auto-stop after 15 seconds max
      setTimeout(function() {
        if (_mediaRecorder && _mediaRecorder.state === 'recording') {
          _mediaRecorder.stop();
          _recording = false;
          var micBtn = document.getElementById('chat-mic-btn');
          if (micBtn) { micBtn.classList.remove('recording'); micBtn.textContent = '🎤'; }
          showToast('⏰ 已达最长录音时间 (15″)', 'info');
        }
      }, 15000);
    };
    _mediaRecorder.onstop = function() {
      stream.getTracks().forEach(function(t) { t.stop(); });
      if (_audioChunks.length === 0) return;
      var blob = new Blob(_audioChunks, {type: mimeType});
      var duration = Math.max(1, Math.round((Date.now() - _recordStartTime) / 1000));
      var reader = new FileReader();
      reader.onloadend = function() {
        var base64 = reader.result.split(',')[1];
        sendVoiceMessage(base64, duration, mimeType);
      };
      reader.readAsDataURL(blob);
    };
    _mediaRecorder.start(250);
  }).catch(function(err) {
    _recording = false;
    var micBtn = document.getElementById('chat-mic-btn');
    if (micBtn) { micBtn.classList.remove('recording'); micBtn.textContent = '🎤'; }
    showToast('无法访问麦克风: ' + (err.message || '权限未授予'), 'error');
  });
}

function stopRecording(e) {
  if (!_recording) return;
  e.preventDefault();
  _recording = false;
  var micBtn = document.getElementById('chat-mic-btn');
  if (micBtn) {
    micBtn.classList.remove('recording');
    micBtn.textContent = '🎤';
  }
  if (_mediaRecorder && _mediaRecorder.state === 'recording') {
    _mediaRecorder.stop();
  }
}

function sendVoiceMessage(base64, duration, mimeType) {
  var user = getCurrentUser();
  if (!user) return;

  var msgId = Date.now();
  var voiceExt = mimeType.indexOf('webm') !== -1 ? 'webm' : (mimeType.indexOf('mp4') !== -1 ? 'mp4' : 'webm');
  var voiceFile = 'data/voice/' + msgId + '.' + voiceExt;

  var msg = {
    id: msgId,
    fromMemberId: user.memberId,
    fromMemberName: user.memberName,
    type: 'voice',
    voiceFile: voiceFile,
    audioBase64: base64,   // keep locally for instant playback
    audioMime: mimeType,
    duration: duration,
    created: Date.now()
  };

  // Save locally first (with audioBase64 for instant playback)
  try {
    var msgs = getMessages();
    msgs.push(msg);
    saveMessages(msgs);
    _messagesCache = msgs;
    updateChatBadge();
    renderChatMessages();
    scrollChatToBottom();
  } catch(e) {}

  setSyncState('saving');

  // Upload audio to separate file, then save message reference (without audioBase64)
  ghApiPut(voiceFile, base64, '', function(err, data) {
    if (!err) {
      setSyncState('synced');
      saveMsgRefToGithub(msg);
    } else {
      // Audio upload failed — keep base64 locally, mark as failed
      var local = [];
      try { local = JSON.parse(localStorage.getItem('ft_chat_messages') || '[]'); } catch(ex) {}
      // Replace existing ref-only msg with full base64 version
      local = local.filter(function(m) { return m.id !== msg.id; });
      local.push(msg);
      _messagesCache = local;
      try { localStorage.setItem('ft_chat_messages', JSON.stringify(local)); } catch(ex) {}
      updateChatBadge();
      renderChatMessages();
      scrollChatToBottom();
      _failedMsgIds[msg.id] = true;
      showToast('⚠️ 语音已存本地', 'warning');
    }
  });
}

function saveMsgRefToGithub(msg) {
  // Save voice message reference (no audioBase64) — delegate to main save
  var cleanMsg = {};
  for (var k in msg) { if (k !== 'audioBase64') cleanMsg[k] = msg[k]; }
  saveMessageToGithub(cleanMsg);
}

function sendChatMessage() {
  var user = getCurrentUser();
  if (!user) {
    showToast('请先登录后再发言', 'warning');
    toggleLoginPanel();
    return;
  }
  var input = document.getElementById('chat-input');
  var text = input.value.trim();
  if (!text) return;

  var msg = {
    id: Date.now(),
    fromMemberId: user.memberId,
    fromMemberName: user.memberName,
    type: 'text',
    text: text,
    created: Date.now()
  };

  // Always save locally first
  try {
    var msgs = getMessages();
    msgs.push(msg);
    saveMessages(msgs);
    _messagesCache = msgs;
    input.value = '';
    updateChatBadge();
    renderChatMessages();
    scrollChatToBottom();
    // Sync to GitHub
    saveMessageToGithub(msg);
  } catch(e) {
    // Fallback: direct save in case of any error
    var fallback = [];
    try { fallback = JSON.parse(localStorage.getItem('ft_chat_messages') || '[]'); } catch(ex) {}
    fallback.push(msg);
    try { localStorage.setItem('ft_chat_messages', JSON.stringify(fallback)); } catch(ex) {}
    _messagesCache = fallback;
    if (input) input.value = '';
    updateChatBadge();
    renderChatMessages();
    scrollChatToBottom();
    showToast('⚠️ 已存本地', 'warning');
  }
}

function getMessages() {
  var local = [];
  try { local = JSON.parse(localStorage.getItem('ft_chat_messages') || '[]'); } catch(e) {}
  if (isGHReady() && _messagesCache && _messagesCache.length > 0) {
    var result = _messagesCache.slice();
    local.forEach(function(ll) {
      if (!result.some(function(rl) { return rl.id === ll.id; })) {
        result.push(ll);
      }
    });
    result.sort(function(a, b) { return a.created - b.created; });
    return result;
  }
  return local;
}

function saveMessages(msgs) {
  try { localStorage.setItem('ft_chat_messages', JSON.stringify(msgs)); } catch(e) {}
}

function updateChatBadge() {
  var msgs = getMessages();
  var badge = document.getElementById('mail-badge');
  if (!badge) return;
  var count = msgs.length;
  badge.textContent = count > 99 ? '99+' : count;
  badge.style.display = count > 0 ? 'flex' : 'none';
}

function forceRefreshMessages() {
  var btn = document.getElementById('chat-refresh-btn');
  if (btn) btn.style.animation = 'spin 0.5s linear';
  pollMessages();
  setTimeout(function() {
    if (btn) btn.style.animation = '';
    showToast('云端' + _ghRemoteCount + '条 · 本地' + getMessages().length + '条 · 轮询#' + _ghPollCount, 'info');
  }, 500);
}

function updateChatStatus() {
  var el = document.getElementById('chat-status');
  if (!el) return;
  if (isGHReady()) {
    var localCount = 0;
    try { localCount = JSON.parse(localStorage.getItem('ft_chat_messages') || '[]').length; } catch(e) {}
    var timing = _lastPollMs ? ' · ' + _lastPollMs + 'ms' : '';
    var interval = getAdaptiveInterval ? ' · ' + (getAdaptiveInterval()/1000).toFixed(0) + 's' : '';
    var sync = '';
    if (_syncState === 'saving') sync = ' · ⏳';
    else if (_syncState === 'synced') sync = ' · ✅';
    else if (_syncState === 'error') sync = ' · ⚠️';
    el.textContent = (_ghReady?'🟢':'🔴') + ' 云端' + _ghRemoteCount + ' · 本地' + localCount + ' · 轮询#' + _ghPollCount + timing + interval + sync;
  } else {
    el.textContent = '⚡ 本地模式';
  }
}

function updateChatInputState() {
  var user = getCurrentUser();
  var input = document.getElementById('chat-input');
  var btn = document.getElementById('chat-send-btn');
  var mic = document.getElementById('chat-mic-btn');
  var hint = document.getElementById('chat-login-hint');
  if (user) {
    if (input) { input.disabled = false; input.placeholder = '输入消息...'; }
    if (btn) btn.disabled = false;
    if (mic) mic.disabled = false;
    if (hint) hint.style.display = 'none';
  } else {
    if (input) { input.disabled = true; input.placeholder = '请先登录后再发言'; }
    if (btn) btn.disabled = true;
    if (mic) mic.disabled = true;
    if (hint) hint.style.display = 'block';
  }
}

function toggleChatPanel() {
  var panel = document.getElementById('chat-panel');
  var overlay = document.getElementById('chat-panel-overlay');
  if (!panel) return;
  if (panel.classList.contains('open')) {
    closeChatPanel();
  } else {
    updateChatInputState();
    updateChatStatus();
    renderChatMessages();
    panel.classList.add('open');
    overlay.style.display = 'block';
    setTimeout(scrollChatToBottom, 200);
  }
}

function closeChatPanel() {
  var panel = document.getElementById('chat-panel');
  var overlay = document.getElementById('chat-panel-overlay');
  if (panel) panel.classList.remove('open');
  if (overlay) overlay.style.display = 'none';
}

function renderChatMessages() {
  var container = document.getElementById('chat-messages');
  if (!container) return;
  var msgs = getMessages();
  var user = getCurrentUser();
  var myId = user ? user.memberId : -1;

  updateChatStatus();

  // Skip re-render if nothing changed (prevents audio interruption during poll)
  var failedKeys = Object.keys(_failedMsgIds).join(',');
  var fp = msgs.length + '|' + (msgs.length ? msgs[msgs.length-1].id : '') + '|' + (msgs.length ? msgs[msgs.length-1].created : '') + '|' + failedKeys;
  if (fp === _lastRenderedFingerprint && container.children.length > 0) return;
  _lastRenderedFingerprint = fp;

  // Save playing audio state before destroying DOM
  var playingMsgId = null;
  var playingTime = 0;
  var wasPlaying = false;
  var playingAudios = container.querySelectorAll('audio');
  for (var ai = 0; ai < playingAudios.length; ai++) {
    var a = playingAudios[ai];
    if (!a.paused) {
      wasPlaying = true;
      playingTime = a.currentTime;
      // Extract msg ID from audio id: "va1234567890" -> 1234567890
      playingMsgId = parseInt(a.id.replace('va', ''));
      try { a.pause(); } catch(e) {}
      break;
    }
  }

  if (msgs.length === 0) {
    container.innerHTML = '<div class="chat-empty">暂无消息，快来聊天吧 💬</div>';
    return;
  }

  // Sort oldest first (chat style)
  msgs.sort(function(a, b) { return a.created - b.created; });

  var lastDate = '';
  container.innerHTML = msgs.map(function(m) {
    var d = new Date(m.created);
    var timeStr = String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
    var dateStr = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
    var dateSep = '';
    if (dateStr !== lastDate) {
      dateSep = '<div class="chat-date-sep">' + dateStr + '</div>';
      lastDate = dateStr;
    }
    var isOwn = m.fromMemberId === myId;
    var rowClass = isOwn ? 'chat-msg-row own' : 'chat-msg-row other';
    var bubbleClass = isOwn ? 'chat-bubble own' : 'chat-bubble other';
    var senderName = isOwn ? '' : m.fromMemberName || '匿名';
    var senderHTML = senderName ? '<div class="chat-sender">' + escHtml(senderName) + '</div>' : '';

    var contentHTML;
    if (m.type === 'voice' && (m.audioBase64 || m.voiceFile)) {
      var mime = m.audioMime || 'audio/webm';
      var dur = m.duration || 1;
      var barsHTML = '';
      for (var bi = 0; bi < Math.min(dur, 15); bi++) {
        var bh = 4 + Math.floor(Math.random() * 16);
        barsHTML += '<span class="voice-wave-bar" style="height:' + bh + 'px"></span>';
      }
      var audioId = 'va' + m.id;
      var audioSrc;
      if (m.audioBase64) {
        audioSrc = 'data:' + mime + ';base64,' + m.audioBase64;
      } else if (m.voiceFile) {
        audioSrc = 'https://raw.githubusercontent.com/' + window._ghDefaults.repo + '/' + window._ghDefaults.branch + '/' + m.voiceFile;
      }
      contentHTML =
        '<div class="chat-voice-player" data-msg-id="' + m.id + '">' +
        '<button class="voice-play-btn" id="vpb-' + m.id + '" onclick="toggleVoicePlay(\'' + audioId + '\',\'vpb-' + m.id + '\')">▶</button>' +
        '<div class="voice-wave">' + barsHTML + '</div>' +
        '<span class="voice-dur">' + dur + '″</span>' +
        '<audio id="' + audioId + '" src="' + audioSrc + '" preload="none" style="display:none" ' +
        'onended="onVoiceEnded(\'vpb-' + m.id + '\')" ' +
        'onerror="onVoiceError(\'vpb-' + m.id + '\')"></audio>' +
        '</div>';
    } else {
      contentHTML = escHtml(m.text || '');
    }

    var failMark = _failedMsgIds[m.id] ? '<span class="chat-fail-mark" onclick="event.stopPropagation();retryFailedMsg(' + m.id + ')" title="同步失败，点击重试">❗</span>' : '';

    return dateSep +
      '<div class="' + rowClass + '">' +
      senderHTML +
      '<div class="' + bubbleClass + '">' + contentHTML + '</div>' +
      failMark +
      '<div class="chat-time">' + timeStr + '</div>' +
      '</div>';
  }).join('');

  // Restore playing audio state
  if (wasPlaying && playingMsgId) {
    var restoreAudio = document.getElementById('va' + playingMsgId);
    var restoreBtn = document.getElementById('vpb-' + playingMsgId);
    if (restoreAudio) {
      restoreAudio.currentTime = playingTime;
      restoreAudio.play().then(function() {
        if (restoreBtn) { restoreBtn.classList.add('playing'); restoreBtn.textContent = '⏸'; }
      }).catch(function() {});
    }
  }

  // Scroll to bottom after render
  setTimeout(scrollChatToBottom, 100);
}

function scrollChatToBottom() {
  var container = document.getElementById('chat-messages');
  if (container) {
    container.scrollTop = container.scrollHeight;
  }
}

function toggleVoicePlay(audioId, btnId) {
  var audio = document.getElementById(audioId);
  var btn = document.getElementById(btnId);
  if (!audio || !btn) return;
  // Pause all other playing audio
  document.querySelectorAll('.chat-voice-player audio').forEach(function(el) {
    if (el.id !== audioId && !el.paused) { el.pause(); el.currentTime = 0; }
  });
  document.querySelectorAll('.voice-play-btn.playing').forEach(function(el) {
    if (el.id !== btnId) el.classList.remove('playing');
  });
  if (audio.paused) {
    audio.play().catch(function() {});
    btn.classList.add('playing');
    btn.textContent = '⏸';
  } else {
    audio.pause();
    btn.classList.remove('playing');
    btn.textContent = '▶';
  }
}

function onVoiceEnded(btnId) {
  var btn = document.getElementById(btnId);
  if (btn) { btn.classList.remove('playing'); btn.textContent = '▶'; }
}

function onVoiceLoaded(btnId, audio) {
  // Keep wave animation static — audio just enables playback
}

function onVoiceError(btnId) {
  var btn = document.getElementById(btnId);
  if (btn) { btn.textContent = '⚠'; btn.style.background = '#ccc'; }
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Keep sendBirthdayLetter for backward compat (birthday popup uses it)
function sendBirthdayLetter() {
  // Reuse chat send if the birthday popup is open
  var msg = document.getElementById('bday-msg');
  if (msg && msg.value.trim()) {
    document.getElementById('chat-input').value = '🎂 ' + msg.value.trim();
    msg.value = '';
    closeBirthdayPopup();
    toggleChatPanel();
  }
}

</script>

<script>
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js');
}
</script>

<div class="bday-overlay" id="bday-overlay" style="display:none">
  <div class="bday-card">
    <div class="bday-icon">🎂</div>
    <div class="bday-title">🎉 生日快乐！</div>
    <div class="bday-names-area" id="bday-names-area"></div>
    <textarea class="bday-msg" id="bday-msg" placeholder="写下你的生日祝福...💌"></textarea>
    <div class="bday-actions">
      <button class="bday-close" onclick="closeBirthdayPopup()">关闭</button>
      <button class="bday-send" onclick="sendBirthdayLetter()">📨 发送祝福</button>
    </div>
  </div>
</div>
<div class="chat-panel-overlay" id="chat-panel-overlay" onclick="closeChatPanel()"></div>
<div class="chat-panel" id="chat-panel">
  <div class="chat-panel-header">
    <span class="chat-panel-title">💬 家族群聊</span>
    <div style="display:flex;gap:8px;align-items:center">
      <button class="chat-refresh-btn" id="chat-refresh-btn" onclick="forceRefreshMessages()" title="强制刷新">🔄</button>
      <button class="chat-panel-close" onclick="closeChatPanel()">✕</button>
    </div>
  </div>
  <div class="chat-status" id="chat-status"></div>
  <div class="chat-messages" id="chat-messages">
    <div class="chat-empty">暂无消息，快来聊天吧</div>
  </div>
  <div class="chat-login-hint" id="chat-login-hint">请先登录后再发言</div>
  <div class="chat-input-bar">
    <input class="chat-input" id="chat-input" placeholder="输入消息..." onkeydown="if(event.key==='Enter')sendChatMessage()" disabled>
    <button class="chat-mic-btn" id="chat-mic-btn" onmousedown="startRecording(event)" onmouseup="stopRecording(event)" onmouseleave="stopRecording(event)" ontouchstart="startRecording(event)" ontouchend="stopRecording(event)" ontouchcancel="stopRecording(event)" disabled>🎤</button>
    <button class="chat-send-btn" id="chat-send-btn" onclick="sendChatMessage()" disabled>➤</button>
  </div>
</div>


<div class="login-overlay" id="login-overlay" onclick="if(event.target===this)closeLoginPanel()">
  <div class="login-card">
    <div class="login-card-title">👤 家族登录</div>
    <div class="login-card-sub">输入你的名字搜索，然后输入PIN码</div>
    <input class="form-input" id="login-search" placeholder="🔍 搜索你的名字..." oninput="onLoginSearch(this.value)" autocomplete="off" style="width:100%;box-sizing:border-box;margin-bottom:8px;padding:10px 14px;border-radius:10px;border:2px solid #ddd;font-size:.9rem">
    <div class="login-member-list" id="login-member-list" style="max-height:160px"></div>
    <div class="login-pin-row">
      <input class="login-pin-input" id="login-pin" type="password" maxlength="4" placeholder="PIN码" onkeydown="if(event.key==='Enter')doLoginWithPin()">
    </div>
    <div class="login-actions">
      <button class="btn btn-ghost" onclick="closeLoginPanel()">取消</button>
      <button class="btn btn-primary" onclick="doLoginWithPin()">登录</button>
    </div>
    <div class="login-error" id="login-error"></div>
  </div>
</div>
</body></html>