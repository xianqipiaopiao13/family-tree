  config['bg' + cap] = '';
  saveData('ft_config', config);
  updateBgThumb(page);
  applyPageBg(page, '', true);
  if (page === 'hero') applyHeroBg('', true);
}
function updateBgThumb(page) {
  var cap = page.charAt(0).toUpperCase() + page.slice(1);
  var url = config['bg' + cap] || '';
  var thumb = document.getElementById('bg-thumb-' + page);
  var placeholder = document.getElementById('bg-placeholder-' + page);
  if (!thumb || !placeholder) return;
  if (url) {
    thumb.src = url;
    thumb.style.display = 'block';
    placeholder.style.display = 'none';
  } else {
    thumb.src = '';
    thumb.style.display = 'none';
    placeholder.style.display = '';
  }
}
function applyConfig() {
  // On exported standalone files, fill missing config values from __CUSTOM_CONFIG__
  var cc = window.__CUSTOM_CONFIG__;
  if (cc) {
    if (!config.title && cc.title) config.title = cc.title;
    if (!config.sub && cc.sub) config.sub = cc.sub;
    if (!config.year && cc.year) config.year = cc.year;
    if (!config.gen && cc.gen) config.gen = cc.gen;
    if (!config.genBase && cc.genBase) config.genBase = cc.genBase;
    if (!config.motto && cc.motto) config.motto = cc.motto;
    if (!config.selfId && cc.selfId) config.selfId = cc.selfId;
    if (!config.bgHome && cc.bgHome) config.bgHome = cc.bgHome;
    if (!config.bgTree && cc.bgTree) config.bgTree = cc.bgTree;
    if (!config.bgMembers && cc.bgMembers) config.bgMembers = cc.bgMembers;
    if (!config.bgStories && cc.bgStories) config.bgStories = cc.bgStories;
    if (!config.bgHero && cc.bgHero) config.bgHero = cc.bgHero;
  }
  if(config.title) { document.getElementById('hero-title').textContent=config.title; document.getElementById('nav-title').textContent='🏮 '+config.title; document.title=config.title; }
  if(config.sub) document.getElementById('hero-sub').textContent=config.sub;
  if(config.year) document.getElementById('stat-year').textContent=config.year;
  if(config.gen) document.getElementById('stat-gen').textContent=config.gen;
  if(config.motto) document.getElementById('home-motto').textContent=config.motto;
  applyPageBg('home', config.bgHome);
  applyPageBg('tree', config.bgTree);
  applyPageBg('members', config.bgMembers);
  applyPageBg('stories', config.bgStories);
  updateBgThumb('hero');
