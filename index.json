.chat-msg-row.other{align-self:flex-start;align-items:flex-start}
.chat-sender{font-size:.65rem;color:#999;margin-bottom:2px;padding:0 4px}
.chat-bubble{max-width:100%;padding:10px 14px;border-radius:18px;font-size:.85rem;line-height:1.5;word-break:break-word;white-space:pre-wrap}
.chat-bubble.own{background:#4A90D9;color:#fff;border-bottom-right-radius:4px}
.chat-bubble.other{background:#fff;color:#333;border:1px solid #e8e8e8;border-bottom-left-radius:4px}
.chat-time{font-size:.6rem;color:#bbb;margin-top:3px;padding:0 4px}
.chat-fail-mark{font-size:.75rem;cursor:pointer;margin:0 4px;align-self:center;opacity:.7}
.chat-fail-mark:hover{opacity:1}
.chat-input-bar{display:flex;gap:8px;padding:10px 14px;border-top:1px solid #e8e8e8;flex-shrink:0;align-items:center}
.chat-input{flex:1;border:1px solid #ddd;border-radius:20px;padding:10px 16px;font-size:.85rem;outline:none;font-family:inherit;transition:border .2s}
.chat-input:focus{border-color:#4A90D9}
.chat-input:disabled{background:#f5f5f5;color:#999}
.chat-send-btn{width:38px;height:38px;border-radius:50%;border:none;background:#4A90D9;color:#fff;font-size:1rem;cursor:pointer;flex-shrink:0;transition:all .2s;display:flex;align-items:center;justify-content:center}
