.chat-status{font-size:.65rem;color:#999;text-align:center;padding:4px 10px;border-bottom:1px dashed #f0f0f0;flex-shrink:0}
.chat-messages{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:6px}
.chat-empty{text-align:center;color:var(--text-light);padding:40px 20px;font-size:.85rem}
