.chat-send-btn:disabled{background:#ccc;cursor:not-allowed}
.chat-mic-btn{width:38px;height:38px;border-radius:50%;border:none;background:#f0f0f0;color:#666;font-size:1.1rem;cursor:pointer;flex-shrink:0;transition:all .15s;display:flex;align-items:center;justify-content:center;-webkit-tap-highlight-color:transparent;user-select:none;-webkit-user-select:none}
