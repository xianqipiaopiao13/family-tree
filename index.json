const defaultStories = [{"id":2,"title":"朱氏三厢房发源地","date":"1930-1940年代","icon":"📖","desc":"吾朱氏一脉，源溯沛国，源远流长。先祖忠厚立身，勤俭持家，以礼传家，以善待人。世代耕读为本，崇文尚德，尊老睦亲，邻里和睦。族人恪守祖训，明礼知义，安分守己，代代相传。今续修族谱，铭记先祖恩德，传承优良家风，愿后世子孙谨遵礼字辈分，修身立德，勤学上进，忠孝两全，团结族人，兴旺门第，光耀朱氏门庭。","photo":"images/img_187.jpg"},{"id":3,"title":"家庭团圆宴","date":"2023年","icon":"📖","desc":"家庭成员首次大团圆，共叙家情，场面温馨感人。","photo":"images/img_188.jpg"}];

function hashStr(s) {
  var hash = 5381;
  for (var i = 0; i < s.length; i++) {
    hash = ((hash << 5) + hash) + s.charCodeAt(i);
    hash = hash & hash;
  }
  return Math.abs(hash).toString(36);
}

function loadData() {
  try {
    // Compute version from actual embedded data — any data change = new version = auto-clear
    var dataVer = "v3_" + hashStr(JSON.stringify(defaultMembers));
    var storedVer = localStorage.getItem('ft_data_version');
    if (storedVer !== dataVer) {
      localStorage.removeItem('ft_members');
      localStorage.removeItem('ft_stories');
    }
    localStorage.setItem('ft_data_version', dataVer);
    const m = localStorage.getItem('ft_members');
    const s = localStorage.getItem('ft_stories');
    const c = localStorage.getItem('ft_config');
    var fallbackConfig = {};
    if (!c && window.__CUSTOM_CONFIG__) { fallbackConfig = window.__CUSTOM_CONFIG__; }
    return {
      members: m ? JSON.parse(m) : defaultMembers,
      stories: s ? JSON.parse(s) : defaultStories,
      config: c ? JSON.parse(c) : fallbackConfig
    };
  } catch(e) { return {members:defaultMembers,stories:defaultStories,config: window.__CUSTOM_CONFIG__ || {}}; }
}
function saveData(key, val) {
  try { localStorage.setItem(key, JSON.stringify(val)); } catch(e) { showToast('保存失败：存储空间已满。请删除部分照片后重试。', 'error'); }
}



