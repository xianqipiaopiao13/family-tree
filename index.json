// ===== BIRTHDAY SYSTEM =====
var _bdayCurrentPerson = null;

function checkBirthdays() {
  try {
    var today = new Date();
    var todayM = today.getMonth() + 1;
    var todayD = today.getDate();

    // Find living members whose birthday is today
    var birthdays = members.filter(function(m) {
      if (!m.birth) return false;
      if (m.death && m.death.trim()) return false; // deceased
      var bd = parseBirthDate(m.birth);
      if (!bd.month || !bd.day) return false;
      return parseInt(bd.month) === todayM && parseInt(bd.day) === todayD;
    });

    if (birthdays.length > 0) {
      _bdayPeople = birthdays.slice();
      setTimeout(function() {
        showBirthdayPopup(_bdayPeople);
      }, 500);
    }

    // Update mail badge
    updateChatBadge();
  } catch(e) {}
}

var _bdayPeople = [];

function showBirthdayPopup(people) {
  _bdayPeople = people;
  var today = new Date();

  // Build names + ages list
  var namesHTML = '';
  var greetingMsg = '';
  var placeholderMsg = '';

  if (people.length === 1) {
    var p = people[0];
    var age = p.birth ? (today.getFullYear() - parseInt(parseBirthDate(p.birth).year || today.getFullYear())) : '?';
    namesHTML = '<div class="bday-name">' + p.name + '</div>' +
      '<div class="bday-age">' + age + '<span> 岁</span></div>';
    greetingMsg = '🎉 生日快乐！';
    placeholderMsg = '写下你的生日祝福...💌';
  } else {
    greetingMsg = '🎉 同一天生日，双倍快乐！';
    placeholderMsg = '写下对他们的共同祝福...💌';
    namesHTML = '';
    for (var i = 0; i < people.length; i++) {
      var p = people[i];
      var age = p.birth ? (today.getFullYear() - parseInt(parseBirthDate(p.birth).year || today.getFullYear())) : '?';
      namesHTML += '<div class="bday-person">' +
        '<span class="bday-person-name">' + p.name + '</span>' +
        '<span class="bday-person-age">' + age + '岁</span>' +
        '</div>';
    }
    namesHTML += '<div class="bday-together">🌟 同月同日，家族缘分</div>';
  }

  document.querySelector('.bday-title').innerHTML = greetingMsg;
  document.getElementById('bday-names-area').innerHTML = namesHTML;
  document.getElementById('bday-msg').placeholder = placeholderMsg;
  document.getElementById('bday-msg').value = '';
  document.getElementById('bday-overlay').style.display = 'flex';
}

