<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --danger:#c0392b;--success:#27ae60
}
/* ── 水墨丹青 ── */
body[data-theme="ink"]{
  --primary:#2C2C2C;--primary-light:#5A5A5A;--accent:#7A9A7E;
  --bg:#F5F0E8;--card-bg:#FEFCF7;--text:#2C2C2C;
  --text-light:#6B6B6B;--border:#C5C0B5;--shadow:0 2px 12px rgba(44,44,44,.08);
  --accent-text:#2C2C2C;--nav-gradient:linear-gradient(135deg,#2C2C2C 0%,#1A1A1A 100%);
  --hero-gradient:linear-gradient(180deg,#F5F0E8 0%,#E8E2D5 100%);
}
/* ── 朱红鎏金 ── */
body[data-theme="imperial"]{
  --primary:#8B1A1A;--primary-light:#B54444;--accent:#C9A55C;
  --bg:#FFF8E7;--card-bg:#FFFDF5;--text:#3E1F0D;
  --text-light:#7A5A3A;--border:#D4C5A0;--shadow:0 2px 12px rgba(139,26,26,.08);
  --accent-text:#3E1F0D;--nav-gradient:linear-gradient(135deg,#8B1A1A 0%,#5C0E0E 100%);
  --hero-gradient:linear-gradient(180deg,#FFF8E7 0%,#F5E6C8 100%);
}
/* ── 青花雅韵 ── */
body[data-theme="porcelain"]{
  --primary:#1E3A5F;--primary-light:#5B8DB8;--accent:#4A7FB5;
  --bg:#F4F7FA;--card-bg:#FFFFFF;--text:#1A2530;
  --text-light:#5A6B7A;--border:#C8D6E5;--shadow:0 2px 12px rgba(30,58,95,.08);
  --accent-text:#FFFFFF;--nav-gradient:linear-gradient(135deg,#1E3A5F 0%,#0F2440 100%);
  --hero-gradient:linear-gradient(180deg,#F4F7FA 0%,#E3EAF2 100%);
}
/* ── 古卷书香 ── */
body[data-theme="scroll"]{
  --primary:#5D3A1A;--primary-light:#8B6B4A;--accent:#B8956A;
  --bg:#F0E4C8;--card-bg:#FBF5E8;--text:#2C1810;
  --text-light:#6B4D3A;--border:#C4B090;--shadow:0 2px 12px rgba(93,58,26,.08);
  --accent-text:#2C1810;--nav-gradient:linear-gradient(135deg,#5D3A1A 0%,#3E2008 100%);
  --hero-gradient:linear-gradient(180deg,#F0E4C8 0%,#E5D5B0 100%);
}
/* ── 默认（朱红鎏金）── */
body:not([data-theme]){
  --primary:#8B1A1A;--primary-light:#B54444;--accent:#C9A55C;
  --bg:#FFF8E7;--card-bg:#FFFDF5;--text:#3E1F0D;
  --text-light:#7A5A3A;--border:#D4C5A0;--shadow:0 2px 12px rgba(139,26,26,.08);
  --accent-text:#3E1F0D;--nav-gradient:linear-gradient(135deg,#8B1A1A 0%,#5C0E0E 100%);
  --hero-gradient:linear-gradient(180deg,#FFF8E7 0%,#F5E6C8 100%);
}
body{font-family:'Noto Serif SC','PingFang SC','Microsoft YaHei',sans-serif;background:transparent;color:var(--text);min-height:100vh;transition:background .3s,color .3s;padding-bottom:56px}
/* Top header bar */
.top-header{position:sticky;top:0;z-index:100;background:#fff;padding:10px 16px;
  display:flex;align-items:center;justify-content:space-between;height:48px;
  border-bottom:1px solid #e8e8e8;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.header-title{font-size:1.05rem;font-weight:bold;color:var(--text);letter-spacing:2px}
.header-actions{display:flex;align-items:center;gap:8px}
/* Bottom tab bar */
.music-btn{width:36px;height:36px;border-radius:50%;border:none;
  background:rgba(255,255,255,.85);font-size:1.1rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 2px 8px rgba(0,0,0,.12);transition:all .2s;
  -webkit-tap-highlight-color:transparent}
.music-btn:active{transform:scale(.9)}
.music-btn.off{opacity:.5;background:rgba(255,255,255,.6)}
.tab-bar{position:fixed;bottom:0;left:0;right:0;height:56px;background:#fff;
  display:flex;border-top:1px solid #e8e8e8;z-index:200;
  padding-bottom:env(safe-area-inset-bottom);box-shadow:0 -1px 3px rgba(0,0,0,.04)}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  color:#999;font-size:.65rem;gap:3px;transition:color .2s;cursor:pointer;
  border:none;background:none;font-family:inherit;padding:0;-webkit-tap-highlight-color:transparent}
.tab-item.active{color:var(--primary);font-weight:600}
.tab-icon{font-size:1.25rem;line-height:1}
.admin-badge{background:var(--accent);color:var(--accent-text);padding:4px 10px;border-radius:12px;
  font-size:.76rem;font-weight:bold;cursor:pointer;border:none;font-family:inherit}
.self-badge{background:var(--primary);color:#fff;padding:4px 10px;border-radius:14px;
  font-size:.78rem;font-weight:bold;cursor:pointer;border:2px solid var(--accent);font-family:inherit;
  display:inline-flex;align-items:center;gap:4px;transition:all .2s}
.self-badge:hover{background:var(--danger);border-color:var(--danger)}
.theme-btn{background:#f0f0f0;border:1px solid #ddd;color:var(--text);
  padding:4px 10px;border-radius:14px;cursor:pointer;font-size:.82rem;font-family:inherit;
  transition:background .2s;margin-right:5px}
.theme-btn:hover{background:#e0e0e0}
.theme-panel{display:none;position:fixed;top:56px;right:12px;background:#fff;
  border:1px solid #e8e8e8;border-radius:14px;padding:14px 16px;z-index:150;
  box-shadow:0 8px 32px rgba(0,0,0,.18);grid-template-columns:1fr 1fr;gap:10px}
.theme-panel.open{display:grid}
.theme-option{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:10px;
  cursor:pointer;border:2px solid transparent;transition:all .2s;font-size:.82rem;
  color:var(--text);font-family:inherit;background:var(--bg);white-space:nowrap}
.theme-option:hover{border-color:var(--primary-light)}
.theme-option.active{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent)}
.theme-dot{width:20px;height:20px;border-radius:50%;flex-shrink:0;box-shadow:inset 0 1px 2px rgba(0,0,0,.15)}
/* ── Splash 引导页 ── */
.splash{position:fixed;inset:0;z-index:9999;background:#0a0a0a;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  transition:opacity .5s;cursor:pointer;user-select:none;touch-action:manipulation}
.splash.fade-out{opacity:0;pointer-events:none}
.splash-slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  flex-direction:column;opacity:0;transition:opacity .6s ease;padding:40px 24px}
.splash-slide.active{opacity:1}
.splash-slide-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-attachment:fixed;
  z-index:0}
.splash-slide-bg::after{content:'';position:absolute;inset:0;background:rgba(0,0,0,.45);z-index:1}
.splash-slide-content{position:relative;z-index:2;text-align:center;color:#fff}
.splash-slide-icon{font-size:3.6rem;margin-bottom:16px;animation:splashFadeUp .8s ease}
.splash-slide-title{font-size:2rem;font-weight:bold;letter-spacing:6px;margin-bottom:12px;
  font-family:'Noto Serif SC',SimSun,serif;animation:splashFadeUp .8s ease .15s both}
.splash-slide-sub{font-size:1rem;color:rgba(255,255,255,.75);letter-spacing:3px;
  line-height:1.8;animation:splashFadeUp .8s ease .3s both}
@keyframes splashFadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.splash-dots{position:absolute;bottom:80px;left:50%;transform:translateX(-50%);
  display:flex;gap:10px;z-index:3}
.splash-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.35);
  transition:all .3s;cursor:pointer}
.splash-dot.active{background:#fff;box-shadow:0 0 8px rgba(255,255,255,.5);width:28px;border-radius:5px}
.splash-skip{position:absolute;top:28px;right:28px;z-index:3;background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.25);color:#fff;padding:7px 18px;border-radius:20px;
  font-size:.85rem;cursor:pointer;font-family:inherit;letter-spacing:2px;transition:background .2s}
.splash-skip:hover{background:rgba(255,255,255,.25)}
.splash-hint{position:absolute;bottom:34px;left:50%;transform:translateX(-50%);z-index:3;
  color:rgba(255,255,255,.4);font-size:.76rem;letter-spacing:2px}
.splash-replay{display:none;background:transparent;border:none;color:var(--accent);
  cursor:pointer;font-size:.78rem;font-family:inherit;letter-spacing:1px;padding:4px 8px}
.splash-replay.visible{display:inline}
.splash-admin-controls{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:4;
  display:none;gap:10px}
.admin-mode .splash-slide.active .splash-admin-controls{display:flex}
.splash-admin-btn{width:36px;height:36px;border-radius:50%;border:2px solid rgba(255,255,255,.6);
  background:rgba(0,0,0,.4);color:#fff;cursor:pointer;font-size:.9rem;
  display:flex;align-items:center;justify-content:center;transition:all .2s}
.splash-admin-btn:hover{background:rgba(255,255,255,.25);border-color:#fff}
.splash-admin-btn.del{background:rgba(192,57,43,.7);border-color:rgba(255,255,255,.4)}
.splash-admin-btn.del:hover{background:rgba(192,57,43,.95)}
.splash-add-slide{position:absolute;bottom:110px;left:50%;transform:translateX(-50%);z-index:3;
  display:none;align-items:center;gap:4px;background:rgba(255,255,255,.12);
  border:1px dashed rgba(255,255,255,.35);color:#fff;padding:6px 16px;border-radius:20px;
  cursor:pointer;font-size:.8rem;font-family:inherit;transition:all .2s}
.splash-add-slide:hover{background:rgba(255,255,255,.22)}
.admin-mode .splash-add-slide{display:flex}
.splash-slide-index{z-index:4;position:absolute;top:16px;left:50%;transform:translateX(-50%);
  color:rgba(255,255,255,.4);font-size:.7rem;letter-spacing:1px;display:none}
.admin-mode .splash-slide.active .splash-slide-index{display:block}
.page{display:none;padding:16px;max-width:800px;margin:0 auto;animation:fadeIn .25s ease}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.hero{text-align:center;padding:32px 18px 24px;background:#fff center/cover;
  border-radius:16px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);position:relative;overflow:hidden}
.hero.has-hero-bg .hero-title,.hero.has-hero-bg .hero-sub,.hero.has-hero-bg .hero-divider,.hero.has-hero-bg .hero-stats{position:relative;z-index:1}
.hero.has-hero-bg::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,.75);z-index:0}
.hero.has-hero-bg{background-color:#f5f0e8}
.hero-title{font-size:1.8rem;color:var(--primary);letter-spacing:4px;margin-bottom:6px;font-weight:bold}
.hero-sub{font-size:.88rem;color:var(--text-light);letter-spacing:1px;margin-bottom:16px}
.hero-divider{width:60px;height:2px;background:var(--accent);margin:0 auto 14px;border-radius:1px}
.hero-stats{display:flex;justify-content:center;gap:28px;flex-wrap:wrap}
.stat{text-align:center}
.stat-num{font-size:1.5rem;color:var(--primary);font-weight:bold}
.stat-label{font-size:.75rem;color:var(--text-light);margin-top:2px}
.section-title{font-size:1.05rem;color:var(--text);letter-spacing:2px;
  font-weight:600;margin-bottom:14px;padding-left:4px}
.nav-card-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.nav-card{background:#fff;border:none;border-radius:14px;
  padding:22px 16px;text-align:center;cursor:pointer;box-shadow:0 1px 3px rgba(0,0,0,.06);transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:8px}
.nav-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.1)}
.nav-card-icon{font-size:2rem}
.nav-card-label{font-size:.85rem;font-weight:600;color:var(--text)}
.nav-card-desc{font-size:.7rem;color:var(--text-light)}
.admin-panel{background:#fff;border:1.5px solid var(--accent);
  border-radius:14px;padding:16px 18px;margin-bottom:16px;display:none}
.admin-panel.visible{display:block}
.admin-panel-title{font-size:.9rem;color:var(--primary);font-weight:600;margin-bottom:10px}
.admin-actions{display:flex;gap:8px;flex-wrap:wrap}

/* ===== TREE STYLES ===== */
.tree-wrap{overflow:auto;padding:30px 20px;background:var(--card-bg);
  border-radius:12px;border:1px solid var(--border);box-shadow:var(--shadow);min-height:300px}
.tree-svg-container{position:relative;min-width:800px}
/* Branch tree layout */
.tree-root{display:inline-flex;flex-direction:column;align-items:center;padding:0 8px}
.tree-node-row{display:flex;align-items:center;gap:0;position:relative}
/* Couple unit: person + spouse side by side */
.couple-unit{display:flex;align-items:center;gap:4px;position:relative}
.spouse-connector{font-size:1rem;color:var(--accent);font-weight:bold;padding:0 2px;line-height:1;margin-top:-4px}
/* Node card */
.t-node{background:var(--card-bg);border:2px solid var(--border);border-radius:10px;
  padding:8px 10px;text-align:center;width:96px;cursor:pointer;transition:all .2s;
  box-shadow:var(--shadow);flex-shrink:0;position:relative}
.t-node:hover{border-color:var(--primary-light);transform:translateY(-2px);box-shadow:0 6px 18px rgba(139,69,19,.18)}
.t-node.gen-1{border-color:var(--primary);background:var(--hero-gradient)}
.t-node.gen-2{border-color:var(--primary-light)}
.t-node.gen-3{border-color:#A0522D}
.t-node.gen-4{border-color:#C4A882}
.t-node.gen-5{border-color:#D4C4B0}
.t-node.spouse{border-style:dashed;border-color:var(--accent);background:#FFFBF0}
.t-node.add-btn{border-style:dashed;border-color:var(--border);background:transparent;
  color:var(--text-light);font-size:1.4rem;display:none;width:36px;height:36px;
  padding:0;border-radius:50%;align-items:center;justify-content:center;cursor:pointer}
.admin-mode .t-node.add-btn{display:flex}
.t-av{width:48px;height:48px;border-radius:50%;background:var(--primary-light);
  margin:0 auto 4px;display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;color:#fff;font-weight:bold;overflow:hidden}
.t-av img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.t-name{font-size:.7rem;font-weight:bold;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.t-role{font-size:.6rem;color:var(--text-light);margin-top:1px}
/* Children container */
.children-wrap{display:flex;align-items:flex-start;gap:0;position:relative;padding-top:0;margin-top:0}
/* Vertical line from parent down */
.v-line-down{width:2px;background:var(--border);margin:0 auto;flex-shrink:0}
/* Horizontal line spanning children */
.h-line{height:2px;background:var(--border);flex-shrink:0}
/* Each child branch */
.child-branch{display:flex;flex-direction:column;align-items:center;position:relative}
.child-branch .v-line-up{width:2px;height:24px;background:var(--border);margin:0 auto}
/* Admin node controls */
.node-admin-btns{position:absolute;top:-8px;right:-8px;display:none;gap:2px;z-index:10}
.admin-mode .t-node:hover .node-admin-btns{display:flex}
/* Mobile: always show admin buttons, no hover needed */
.touch-device.admin-mode .node-admin-btns{display:flex}
.node-btn{width:18px;height:18px;border-radius:50%;border:none;cursor:pointer;
  font-size:.6rem;display:flex;align-items:center;justify-content:center;font-family:inherit}
.node-btn-edit{background:var(--accent);color:#5D2E0C}
.node-btn-del{background:var(--danger);color:#fff}
/* Gen label */
.gen-label{font-size:.72rem;color:var(--text-light);letter-spacing:2px;margin-bottom:6px;text-align:center}
/* Tree toolbar */
.tree-toolbar{display:flex;gap:8px;align-items:center;margin-bottom:14px;flex-wrap:wrap}
/* tree-wrap: overflow hidden, no scrollbars, pan/zoom handled by JS */
.tree-wrap{overflow:hidden;padding:0;background:var(--card-bg);
  border-radius:12px;border:1px solid var(--border);box-shadow:var(--shadow);
  min-height:400px;height:70vh;cursor:grab;user-select:none;position:relative}
.tree-hint{position:absolute;top:46px;left:12px;font-size:.7rem;color:var(--text-light);pointer-events:none;z-index:5;opacity:0.6;white-space:nowrap;background:rgba(245,240,232,.7);padding:3px 8px;border-radius:4px}
.tree-wrap.grabbing{cursor:grabbing}

/* Members */
.filter-bar{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:16px}
.filter-btn{padding:6px 16px;border-radius:20px;border:none;
  background:#f0f0f0;cursor:pointer;font-size:.8rem;color:var(--text-light);
  transition:all .2s;font-family:inherit;white-space:nowrap}
.filter-btn:hover,.filter-btn.active{background:var(--primary);color:#fff}
.members-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px}
.member-card{background:#fff;border:none;border-radius:14px;
  padding:18px 12px;text-align:center;cursor:pointer;transition:all .2s;
  box-shadow:0 1px 3px rgba(0,0,0,.06);position:relative}
.member-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.1)}
.member-av{width:54px;height:54px;border-radius:50%;background:var(--primary-light);
  margin:0 auto 9px;display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;color:#fff;font-weight:bold;overflow:hidden}
.member-av img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.member-name{font-size:.9rem;font-weight:bold;color:var(--text);margin-bottom:2px}
.member-gen{font-size:.75rem;color:var(--accent);margin-bottom:2px}
.member-info{font-size:.72rem;color:var(--text-light)}
.member-kinship{font-size:.76rem;color:var(--accent);font-weight:bold;margin-bottom:2px}
.card-edit-btn,.card-del-btn{position:absolute;top:7px;border:none;border-radius:7px;
  padding:2px 7px;font-size:.68rem;cursor:pointer;display:none;font-family:inherit}
.card-edit-btn{right:7px;background:var(--accent);color:#5D2E0C}
.card-del-btn{left:7px;background:var(--danger);color:#fff}
.admin-mode .card-edit-btn,.admin-mode .card-del-btn{display:block}
.stories-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
.story-card{background:#fff;border:none;border-radius:14px;
  overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06);transition:all .2s}
.story-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.1)}
.story-img{height:240px;background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);
  display:flex;align-items:center;justify-content:center;font-size:3.6rem;overflow:hidden}
.story-img img{width:100%;height:100%;object-fit:cover;display:block}
.story-body{padding:18px 16px}
.story-title{font-size:1rem;font-weight:bold;color:var(--text);margin-bottom:6px}
.story-date{font-size:.76rem;color:var(--accent);margin-bottom:8px}
.story-desc{font-size:.83rem;color:var(--text-light);line-height:1.7}
.story-actions{display:none;padding:10px 16px;border-top:1px solid var(--border);gap:7px}
.admin-mode .story-actions{display:flex}
.photo-upload-area{border:2px dashed var(--border);border-radius:10px;padding:14px;
  text-align:center;cursor:pointer;transition:border .2s;margin-bottom:4px}
.photo-upload-area:hover{border-color:var(--primary-light)}
.photo-preview{width:72px;height:72px;border-radius:50%;object-fit:cover;
  margin:0 auto 6px;display:block;border:2px solid var(--border)}
.photo-hint{font-size:.78rem;color:var(--text-light)}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);
  z-index:10000;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:16px;padding:26px;max-width:500px;
  width:92%;max-height:88vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);position:relative}
.modal-close{position:absolute;top:13px;right:13px;background:none;border:none;
  font-size:1.2rem;cursor:pointer;color:var(--text-light)}
.modal-av{width:180px;height:180px;border-radius:12px;background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);
  margin:0 auto 10px;display:flex;align-items:center;justify-content:center;
  font-size:3.6rem;color:#fff;font-weight:bold;overflow:hidden}
.modal-av img{width:100%;height:100%;object-fit:cover;display:block;border-radius:12px}
.modal-name{text-align:center;font-size:1.35rem;color:var(--primary);margin-bottom:2px}
.modal-gen{text-align:center;font-size:.85rem;color:var(--accent);margin-bottom:16px}
.modal-divider{height:1px;background:var(--border);margin:12px 0}
.modal-row{display:flex;gap:7px;margin-bottom:8px;font-size:.86rem}
.modal-label{color:var(--text-light);min-width:54px}
.modal-value{color:var(--text)}
.modal-relations{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px}
.rel-tag{background:var(--bg);border:1px solid var(--accent);color:var(--primary);
  padding:2px 9px;border-radius:12px;font-size:.76rem;cursor:pointer}
.rel-tag:hover{background:var(--accent);color:#fff}
/* Album */
.album-modal .modal{max-width:680px}
.album-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-top:4px}
.album-item{position:relative;border-radius:10px;overflow:hidden;aspect-ratio:1;
  background:var(--bg);cursor:pointer;box-shadow:var(--shadow)}
.album-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .2s}
.album-item:hover img{transform:scale(1.05)}
.album-caption{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.45);
  color:#fff;font-size:.68rem;padding:4px 6px;text-align:center;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.album-del-btn{position:absolute;top:5px;right:5px;width:22px;height:22px;border-radius:50%;
  background:rgba(192,57,43,.85);color:#fff;border:none;cursor:pointer;
  font-size:.75rem;display:none;align-items:center;justify-content:center;z-index:2}
.admin-mode .album-del-btn{display:flex}
.album-add-card{border:2px dashed var(--border);border-radius:10px;aspect-ratio:1;
  display:none;align-items:center;justify-content:center;flex-direction:column;
  gap:6px;cursor:pointer;color:var(--text-light);font-size:.8rem;transition:border .2s}
.album-add-card:hover{border-color:var(--primary);color:var(--primary)}
.admin-mode .album-add-card{display:flex}
.album-empty{color:var(--text-light);font-size:.88rem;padding:30px 0;text-align:center;grid-column:1/-1}
/* Lightbox */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:10002;
  align-items:center;justify-content:center;flex-direction:column}
.lightbox.open{display:flex}
.lightbox-img{max-width:92vw;max-height:78vh;border-radius:8px;object-fit:contain;box-shadow:0 8px 40px rgba(0,0,0,.5)}
.lightbox-caption{color:#ddd;font-size:.88rem;margin-top:12px;max-width:80vw;text-align:center}
.lightbox-close{position:absolute;top:18px;right:22px;color:#fff;font-size:1.6rem;
  cursor:pointer;background:none;border:none;line-height:1}
.lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);
  background:rgba(255,255,255,.15);border:none;color:#fff;font-size:1.6rem;
  cursor:pointer;padding:10px 14px;border-radius:8px;transition:background .2s}
.lightbox-nav:hover{background:rgba(255,255,255,.3)}
.lightbox-prev{left:14px}
.lightbox-next{right:14px}
/* Caption edit in album */
.caption-edit-input{width:100%;padding:4px 7px;border:1px solid var(--border);border-radius:6px;
  font-size:.78rem;font-family:inherit;background:var(--bg);color:var(--text);margin-top:4px}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:.86rem;color:var(--text-light);margin-bottom:4px}
.form-input,.form-select,.form-textarea{width:100%;padding:8px 11px;border:1px solid var(--border);
  border-radius:8px;font-size:.9rem;background:var(--bg);color:var(--text);
  font-family:inherit;transition:border .2s}
.form-input:focus,.form-select:focus,.form-textarea:focus{outline:none;border-color:var(--primary-light)}
.form-textarea{resize:vertical;min-height:68px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.btn{padding:8px 20px;border-radius:8px;font-size:.88rem;cursor:pointer;
  font-family:inherit;border:none;transition:all .2s;letter-spacing:1px}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-light)}
.btn-accent{background:var(--accent);color:#5D2E0C}
.btn-accent:hover{background:#c8960a}
.btn-danger{background:var(--danger);color:#fff}
.btn-danger:hover{background:#a93226}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text-light)}
.btn-ghost:hover{border-color:var(--primary);color:var(--primary)}
.btn-sm{padding:4px 12px;font-size:.76rem}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);
  background:var(--primary);color:#fff;padding:11px 22px;border-radius:24px;font-size:.88rem;
  z-index:999;transition:transform .3s;pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{background:var(--success)}
.toast.error{background:var(--danger)}
.confirm-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:10001;align-items:center;justify-content:center}
.confirm-overlay.open{display:flex}
.confirm-box{background:#fff;border-radius:14px;padding:26px 26px 20px;max-width:320px;width:90%;box-shadow:0 16px 48px rgba(0,0,0,.2)}
.confirm-title{font-size:1.05rem;color:var(--text);margin-bottom:9px;font-weight:bold}
.confirm-msg{font-size:.87rem;color:var(--text-light);margin-bottom:18px;line-height:1.6}
.confirm-actions{display:flex;gap:9px;justify-content:flex-end}
footer{display:none}
/* ── 树搜索 ── */
	.tree-search-wrap{position:absolute;top:8px;left:12px;right:12px;z-index:10;margin-bottom:0}
	.tree-search-input{width:100%;padding:10px 40px 10px 14px;border:1px solid var(--border);border-radius:10px;font-size:.85rem;background:var(--card-bg);color:var(--text);font-family:inherit;outline:none;transition:border-color .2s}
	.tree-search-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(201,165,92,.15)}
	.tree-search-input::placeholder{color:var(--text-light)}
	.tree-search-clear{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:var(--text-light);cursor:pointer;font-size:1.1rem;display:none;padding:2px 6px;border-radius:4px;line-height:1}
	.tree-search-clear:hover{color:var(--text)}
	.tree-search-clear.visible{display:block}
	.tree-search-results{position:absolute;top:100%;left:0;right:0;background:var(--card-bg);border:1px solid var(--border);border-radius:0 0 10px 10px;max-height:220px;overflow-y:auto;z-index:50;display:none;box-shadow:0 6px 20px rgba(0,0,0,.12)}
	.tree-search-results.open{display:block}
	.tree-search-item{padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);font-size:.85rem;display:flex;align-items:center;gap:8px;transition:background .15s}
	.tree-search-item:last-child{border-bottom:none}
	.tree-search-item:hover,.tree-search-item.active{background:var(--bg)}
	.tree-search-item-av{width:32px;height:32px;border-radius:50%;background:var(--primary-light);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:bold;flex-shrink:0}
	.tree-search-item-name{color:var(--text);font-weight:bold}
	.tree-search-item-gen{color:var(--text-light);font-size:.75rem;margin-left:auto}
	.tree-search-empty{padding:14px;text-align:center;color:var(--text-light);font-size:.8rem}
	.t-node.highlight{outline:3px solid var(--accent);outline-offset:4px;border-radius:12px;animation:searchPulse .8s ease-in-out 3}
	@keyframes searchPulse{0%,100%{outline-color:var(--accent)}50%{outline-color:var(--primary)}}

	@media(max-width:600px){
  .top-header{padding:8px 10px;height:auto;gap:6px}
  .header-title{font-size:.85rem;letter-spacing:1px}
  .tab-item{font-size:.6rem;gap:2px}
  .tab-icon{font-size:1.1rem}
  .theme-btn{font-size:.68rem;padding:3px 7px;border-radius:10px;margin-right:0}
  .admin-badge{font-size:.65rem;padding:3px 8px}
  .self-badge{font-size:.65rem;padding:3px 8px}
  
  
  
  
  
  
  .splash-replay{font-size:.65rem;letter-spacing:0}
  .page{padding:12px}.hero-title{font-size:1.6rem}
  .form-row{grid-template-columns:1fr}
  .splash-slide-title{font-size:1.4rem;letter-spacing:4px}
  .splash-slide-sub{font-size:.85rem;letter-spacing:1px}
  .splash-slide-icon{font-size:2.6rem}
  .splash-skip{top:18px;right:14px;font-size:.75rem;padding:5px 14px}
  .splash-hint{bottom:20px;font-size:.7rem}
  .splash-dots{bottom:56px}
  .splash-add-slide{bottom:86px;font-size:.72rem;padding:4px 12px}
}
	/* === Family Card View === */
	.family-view{display:none;padding:0}
	.family-view.active{display:block}
	.family-breadcrumb{display:flex;flex-wrap:wrap;align-items:center;gap:2px;margin-bottom:14px;font-size:.78rem;overflow-x:auto;white-space:nowrap;padding:4px 0}
	.breadcrumb-item{color:var(--primary);cursor:pointer;font-weight:500;padding:2px 6px;border-radius:6px;transition:background .15s}
	.breadcrumb-item:hover{background:rgba(139,26,26,.08)}
	.breadcrumb-item.current{color:var(--text);font-weight:600;cursor:default}
	.breadcrumb-item.current:hover{background:none}
	.breadcrumb-sep{color:var(--text-light);font-size:.65rem;padding:0 2px}
	.family-card{background:#fff;border-radius:14px;padding:14px 16px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);display:flex;align-items:center;gap:12px;cursor:pointer;transition:all .2s;border:2px solid transparent}
	.family-card:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.1)}
	.family-card.self{border-color:var(--primary);background:linear-gradient(135deg,#fffdf7 0%,#fef9f0 100%);box-shadow:0 2px 8px rgba(139,26,26,.12)}
	.family-card.spouse{border-left:3px solid var(--accent)}
	.family-card.parent-card{border-left:3px solid var(--primary-light)}
	.family-card.child-card{}
.family-card.sibling-card{border-left:3px solid #e8c56d}
	.family-card.inlaw-card{border-left:3px solid #7ec8a0}
	.family-card-av{width:48px;height:48px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:#fff;font-weight:bold;overflow:hidden;background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%)}
	.family-card-av img{width:100%;height:100%;object-fit:cover;display:block}
	.family-card-info{flex:1;min-width:0}
	.family-card-name{font-weight:600;color:var(--text);font-size:.92rem;margin-bottom:2px}
	.family-card-detail{font-size:.74rem;color:var(--text-light)}
	.family-card-relation{font-size:.7rem;color:var(--accent);font-weight:500}
	.family-card-arrow{font-size:1.1rem;color:var(--text-light);flex-shrink:0}
	.family-section-title{font-size:.78rem;color:var(--text-light);padding:4px 4px;margin-bottom:6px;font-weight:500;letter-spacing:1px}
	.family-empty{color:var(--text-light);font-size:.82rem;padding:20px 12px;text-align:center;background:#fff;border-radius:12px}
	.family-children-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
	.view-toggle{display:flex;gap:4px;margin-bottom:12px;background:#e8e8e8;border-radius:10px;padding:3px}
	.view-toggle button{flex:1;border:none;background:none;padding:7px 12px;border-radius:8px;font-size:.78rem;cursor:pointer;font-family:inherit;color:var(--text);transition:all .2s}
	.view-toggle button.active{background:#fff;box-shadow:0 1px 2px rgba(0,0,0,.1);font-weight:600;color:var(--primary)}
.bg-picker-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:10px}
.bg-picker{display:flex;flex-direction:column;align-items:center;cursor:pointer}
.bg-preview{width:100%;aspect-ratio:16/10;border-radius:10px;border:2px dashed #ccc;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#f9f9f9;transition:border .2s}
.bg-preview:hover{border-color:var(--primary)}
.bg-preview img{width:100%;height:100%;object-fit:cover;display:block}
.bg-preview.has-bg .bg-placeholder{display:none}
.bg-placeholder{color:#bbb;font-size:.7rem;text-align:center;line-height:1.4}
@media(max-width:600px){
  .bg-picker-grid{grid-template-columns:1fr 1fr}
  .family-children-grid{grid-template-columns:1fr}
  .family-card{padding:12px 14px;gap:10px}
  .family-card-av{width:42px;height:42px;font-size:1rem}
	}

/* ── 密码锁 ── */
#lock-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  background:linear-gradient(180deg,#F5F0E8 0%,#E8E2D5 100%);
  font-family:system-ui,-apple-system,sans-serif}
#lock-overlay.hidden{display:none}
.lock-card{text-align:center;padding:40px 30px;max-width:360px;width:90%}
.lock-icon{font-size:60px;margin-bottom:16px}
.lock-title{font-size:22px;font-weight:700;color:#4a3000;margin-bottom:8px}
.lock-subtitle{font-size:14px;color:#8B7355;margin-bottom:28px}
.lock-input-wrap{display:flex;gap:8px;justify-content:center;margin-bottom:12px}
