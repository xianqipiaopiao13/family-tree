.chat-mic-btn:disabled{background:#f5f5f5;color:#ccc;cursor:not-allowed}
.chat-mic-btn.recording{background:#ff4444;color:#fff;animation:mic-pulse .8s infinite}
@keyframes mic-pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,68,68,.5)}50%{box-shadow:0 0 0 10px rgba(255,68,68,0)}}
.chat-voice-player{display:inline-flex;align-items:center;gap:6px;min-width:140px;max-width:220px;height:34px}
.chat-voice-player .voice-play-btn{width:30px;height:30px;border-radius:50%;border:none;background:#4A90D9;color:#fff;font-size:.75rem;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center}
